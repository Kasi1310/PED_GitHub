@model List<UserProjectRole> 
    <div class="form-group">
             @Html.DropDownList("ProjectId", new SelectList(Model, "ProjectRoleID", "ProjectName"), "Select a Project", new { @class = "form-control ProjectDetails" })
    </div>
<div class="login-buttons">
    <div class="form-group col-sm-6 text-center">
        <input type="submit" id="btnPrjSubmit" class="btn btn-primary btn-block btn-md" value="Submit" />
    </div>
    <div class="form-group col-sm-6 text-center">
        <input type="submit" id="btnPrjCancel" class="btn btn-default btn-block btn-md" value="Cancel" />
    </div>
 </div>
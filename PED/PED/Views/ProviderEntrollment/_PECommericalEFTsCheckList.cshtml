                    </select>
                    @Html.HiddenFor(m => m.PECommericalEFTsCheckList.UpdateOther)
                </div>
            </div>
            <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                @Html.TextBoxFor(m => m.PECommericalEFTsCheckList.Payer, new { @class = "form-control", @placeholder = "Enter Payer", })
                @Html.HiddenFor(m => m.PEDetails.CommericalEFTsCheckListPayer)
            </div>
        </div>
    </div>
</form>
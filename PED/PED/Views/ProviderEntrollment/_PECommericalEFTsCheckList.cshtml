                    <select id="ddlCEFTsUpdateHumana" class="form-control clsCEFTsUpdateHumana" @isEnabled>
                        <option value="Not Started">Not Started</option>
                        <option value="Completed">Completed</option>
                        <option value="NA">NA</option>
                    </select>
                    @Html.HiddenFor(m => m.PECommericalEFTsCheckList.UpdateHumana)
                </div>
            </div>
            <div class="col-md-3 col-sm-3 col-lg-3 p-0">
                <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                    <select id="ddlCEFTsUpdateAetnaTricareEastTricareForLife" class="form-control clsCEFTsUpdateAetnaTricareEastTricareForLife" @isEnabled>
                        <option value="Not Started">Not Started</option>
                        <option value="Completed">Completed</option>
                        <option value="NA">NA</option>
                    </select>
                    @Html.HiddenFor(m => m.PECommericalEFTsCheckList.UpdateAetnaTricareEastTricareForLife)
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-12">
        <div class="form-group" style="margin-bottom: 5px !important;">
            <div class="col-sm-3 col-md-3 col-lg-3 p-0">

@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    string isPermission = "";
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isPermission = "hide";
        isAdmin = "hide";
    }
}

<div class="row m-10">

    <table id="tblPERefusedEnrollmentList" class="table table-striped table-bordered">
        <thead>
            <tr>              
                <th>Insurance Name</th>
                <th>Status</th>
                <th>Comments</th>                
                <th class="@isAdmin">Action</th>
            </tr>
        </thead>
        <tbody>

            @{int i = 0;
                foreach (var item in Model.PERefusedEnrollmentList)
                {
                    i++;
                    <tr id="@item.Id">                        
                        <td class="tr1">@item.RefusedEnrollmentInsuranceName</td>
                        <td class="tr1">@item.RefusedEnrollmentStatus</td>
                        <td class="tr1">@item.RefusedEnrollmentComments</td>                       
                        <td class="tr1">
                            <button id="btnRefusedEnrollmentEdit" type="button" Onclick="EditPERefusedEnrollment('@item.Id')" title="Edit" class="fa fa-lg fa-edit  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>
                            <button id="btnRefusedEnrollmentDelete" type="button" Onclick="ConfirmPERefusedEnrollmentDelete('@item.Id')" title="Delete" class="fa fa-lg fa-trash-o  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>

                        </td>
                    </tr>
                }
            }
        </tbody>
        <tfoot>

        </tfoot>
    </table>
    </div>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");

    var IsDeleted = HttpContextAccessor.HttpContext.Session.Get<string>("SessionPEDetailsDeleted");

    if (RolePermission == "R" || IsDeleted == "true")
    {
        isAdmin = "hide";
    }
}

<form id="PEClientsBankInfofrm" method="post" class="form-horizontal">
    <div class="panel panel-inverse col-lg-12" data-sortable-id="form-validation-1">
        <div class="panel-heading">
            <h6 class="panel-title" id="changeteam">Client Bank Info</h6>
        </div>
        <div class="panel-body panel-form p-t-15 m-t-10">
            <div class="row col-12 p-10" id="CompanyDetails">
                <div class="col-lg-12 @isAdmin">
                    <div class="form-group" style="margin-bottom: 5px !important;">
                        <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                            <input type="button" id="btnClientsBankInfoAdd" class="btn btn-success m-r-5" onclick="btnClientsBankInfo()" value="Add Client's Bank Info" />
                            <input type="button" id="btnBankLetterUploadAdd" class="btn btn-success m-r-5" onclick="btnBankLetterUpload()" value="Upload Bank Letter" />
                        </div>
                        
                    </div>
                    
                </div>
                <div class="col-lg-12 hide" id="divClientsBankInfoForm">
                    @{
                        Html.RenderPartial("_PEClientsBankInfoForm", Model);
                    }
                </div>
                <div class="col-lg-12" id="divClientsBankInfoList">
                    @{
                        Html.RenderPartial("_PEClientsBankInfoList", Model);
                    }
                </div>
                <div class="col-lg-12 hide" id="divBankLetterUpload">
                    @{
                        Html.RenderPartial("_PEClientsBankInfoBankLetterUploadForm", Model);
                    }
                </div>
                <div class="col-lg-12 hide" id="divBankLetterInfoList">
                    @{
                        Html.RenderPartial("_PEClientsBankInfoBankLetterUploadList", Model);
                    }
                </div>
            </div>
        </div>
    </div>
</form>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}

<form id="PEDocumentsListfrm" method="post" class="form-horizontal">
    <div class="row col-12 p-10" id="DocumentsList">
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-12 col-md-12 col-lg-12 p-0">
                    <table id="tblPEDocumentsList" class="table table-striped table-bordered">
                        <thead>
                            <tr role="row">
                                <th>
                                    <input type="checkbox" name="select_all" value="0" id="document-select-all" onclick="PEDocumentSelectAll(this)">
                                </th>
                                <th>Title</th>
                                <th class="hide">Doc</th>
                                <th>Document</th>
                                <th>Added On</th>
                                <th class="tr1">Action</th>
                            </tr>
                        </thead>
                        <tbody>

                            @{int i = 0;
                                foreach (var item in Model.PEDocumentsList)
                                {
                                    i++;
                                    <tr role="row" id="@item.Id">
                                        @*<td id="tdSno" class="tr1">@i</td>*@
                                        <td class="tr1"><input type="checkbox" name="id[]" value="' + @item.Id + '"></td>
                                        <td class="tr1">@item.Title</td>
                                        <td class="tr1 hide">@item.FileName</td>
                                        <td class="tr1">@item.DocumentName</td>
                                        <td class="tr1">@item.AddedOn</td>
                                        <td class="tr1">
                                            <a class="btnDocview fa fa-download text-inverse form-control1 p-l-0 p-r-0 m-5 text-decoration"
                                               href="/ProviderEntrollment/ViewPEDetailsFile?fileName=@item.FileName.Trim()"></a>
                                            <button id="btnPEDocumentDelete" type="button" Onclick="ConfirmPEDocumentDelete('@item.Id')" title="Delete" class="fa fa-lg fa-trash-o  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>

                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</form>
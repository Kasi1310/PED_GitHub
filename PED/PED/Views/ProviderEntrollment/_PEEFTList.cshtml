@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}

<div class="row m-10">
  
    <table id="tblPEEFTList" class="table table-striped table-bordered">
        <thead>
            <tr>
                <tr>              
                <th>Payer Name</th>
                <th>Bank Type</th>
                <th>Comments</th>                
                <th class="@isAdmin">Action</th>
            </tr>
            </tr>
        </thead>
         <tbody>

            @{int i = 0;
                foreach (var item in Model.PEEFTList)
                {
                    i++;
                    <tr id="@item.Id">                        
                        <td class="tr1">@item.EFTPayerName</td>
                        <td class="tr1">@item.EFTBankType</td>
                        <td class="tr1">@item.EFTComments</td>                       
                        <td class="tr1">
                            <button id="btnEFTEdit" type="button" Onclick="EditPEEFT('@item.Id')" title="Edit" class="fa fa-lg fa-edit  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>
                            <button id="btnEFTDelete" type="button" Onclick="ConfirmPEEFTDelete('@item.Id')" title="Delete" class="fa fa-lg fa-trash-o  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>

                        </td>
                    </tr>
                }
            }
        <tfoot>

        </tfoot>
    </table>
    
    </div>
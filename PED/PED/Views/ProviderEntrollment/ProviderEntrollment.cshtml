        function SetClientsBankInfoCity() {
            var StateId = $('#hfClientsBankInfoStateId').val();
            var CityId = $('#hfClientsBankInfoCityId').val();
            var url = '@Url.Action("GetCity", "Admin")';
            var jsonData = { StateId: StateId };

            AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                $($('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)')).get(0).options.length = 0;
                $("<option value = >Select City</option>").appendTo($('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)'));
                $.each(resp, function (index) {
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)').append($("<option></option>").attr('value', this.id).text(this.value));
                });
                if (CityId != 'undefined' && CityId != null && CityId != '') {
                    $($('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)')).val(CityId);
                }
            });
        }

        function DownloadMedicalMutualwithW_9PIForm(ClientId) {
            var url = "@Url.Action("DownloadMedicalMutualwithW_9Form", "ProviderEntrollment")";
            var jsonData = ClientId;
            AjaxRequestJsonPostContent(url, jsonData, function (resp, status, req) {
                const a = document.createElement('a');
                a.style.display = 'none';
                a.href = resp;
                if (ClientId == 0) {
                    a.download = 'W9.zip';

        function StatesOnchange() {
            $('.StatesList').live('change', function () {
                var StateId = $(this).val();
                $('#hfStateId').val(StateId);
                SetCity();
            });
        }

        function SetCity() {
            var StateId = $('#hfStateId').val();
            var CityId = $('#hfCityId').val();
            var url = '@Url.Action("GetCity", "Admin")';
            var jsonData = { StateId: StateId };


            AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                $($('#@Html.IdFor(m => m.PEDetails.CityId)')).get(0).options.length = 0;
                $("<option value = >Select a City</option>").appendTo($('#@Html.IdFor(m => m.PEDetails.CityId)'));
                $.each(resp, function (index) {
                    $('#@Html.IdFor(m => m.PEDetails.CityId)').append($("<option></option>").attr('value', this.id).text(this.value));
                });
                if (CityId != 'undefined' && CityId != null && CityId != '') {

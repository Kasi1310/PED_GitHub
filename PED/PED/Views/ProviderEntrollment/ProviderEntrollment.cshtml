        function EditPECredentialingLicense(CredentialingLicenseID) {

            var url = "@Url.Action("EditPECredentialingLicense", "ProviderEntrollment")";
            var formData = new FormData();
            formData.append('Id', CredentialingLicenseID);

            $.ajax({
                url: url,
                type: "POST",
                contentType: false,
                processData: false,
                data: formData,
                success: function (result) {
                    $('#@Html.IdFor(m => m.PECredentialingLicense.Id)').val(result.data["id"]);
                    $('#@Html.IdFor(m => m.PECredentialingLicense.ClientDetailsID)').val(result.data["clientDetailsID"]);
                    $('#@Html.IdFor(m => m.PECredentialingLicense.LicenseTypeID)').val(result.data["licenseTypeID"]);
                    $('#@Html.IdFor(m => m.PECredentialingLicense.CertificationLevelID)').val(result.data["certificationLevelID"]);
                    $('#@Html.IdFor(m => m.PECredentialingLicense.LicenseNo)').val(result.data["licenseNo"]);
                    $('#@Html.IdFor(m => m.PECredentialingLicense.IssuedDate)').val(result.data["issuedDate"]);
                    $('#@Html.IdFor(m => m.PECredentialingLicense.EffectiveDate)').val(result.data["effectiveDate"]);
                    $('#@Html.IdFor(m => m.PECredentialingLicense.ExpiryDate)').val(result.data["expiryDate"]);

                    $('#divCredentialingLicenseForm').addClass('show');
                    $('#divCredentialingLicenseForm').removeClass('hide');
                    $("#btnPECredentialingLicenseInsert").prop('value', 'Update');
                },
                error: function (err) {
                }
            });
        }

        function ConfirmPECredentialingLicenseDelete(CredentialingLicenseID) {
            var response = swal({
                title: "Are you sure?",
                text: "You will not be able to recover this detail!",
                type: "error",
                showCancelButton: true,
                confirmButtonClass: 'btn-danger',
                confirmButtonText: 'Yes, delete it!'
            },
            function (isConfirm) {
                if (isConfirm) {
                    var url = "@Url.Action("DeletePECredentialingLicense", "ProviderEntrollment")";
                    var jsonData = { Id: CredentialingLicenseID };
                    AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                        PECredentialingLicenseDatatable();
                        ClearPECredentialingLicense();
                    });
                }
                else {
                    return false;
                }
            });
        }

        function ClearPECredentialingLicense() {
            $('#@Html.IdFor(m => m.PECredentialingLicense.Id)').val("0");
            $('#@Html.IdFor(m => m.PECredentialingLicense.LicenseTypeID)').val("");
            $('#@Html.IdFor(m => m.PECredentialingLicense.CertificationLevelID)').val("");
            $('#@Html.IdFor(m => m.PECredentialingLicense.LicenseNo)').val("");
            $('#@Html.IdFor(m => m.PECredentialingLicense.IssuedDate)').val("");
            $('#@Html.IdFor(m => m.PECredentialingLicense.EffectiveDate)').val("");
            $('#@Html.IdFor(m => m.PECredentialingLicense.ExpiryDate)').val("");

            $('#divCredentialingLicenseForm').addClass('hide');
            $('#divCredentialingLicenseForm').removeClass('show');
            $("#btnPECredentialingLicenseInsert").prop('value', 'Add');
        }

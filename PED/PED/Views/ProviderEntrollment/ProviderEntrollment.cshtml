    var RoleId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleID");
    var NotificationCount = HttpContextAccessor.HttpContext.Session.Get<string>("NotificationCount");
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    var IsDeleted = HttpContextAccessor.HttpContext.Session.Get<string>("SessionPEDetailsDeleted");
    string UserId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionUserID");

    string CopyPEOtherAddressID = HttpContextAccessor.HttpContext.Session.Get<string>("CopyPEOtherAddressID");

    string IsSuperAdmin = "fasle";
    if (RoleId == "2c0cdf89-9984-4f82-bcf3-f3382e5a843c")
    {
        IsSuperAdmin = "true";
    }

    if (RoleId == "194c4cc1-4a1e-4861-abbb-302d02f7d825")
    {
        isAdmin = "AE";
    }
    //else if (RoleId == "bc0adea4-0a8b-49f6-9702-8376d9cd2ad4")
    //{
    //    isSU = "true"; //Provider Enrollment Limited Access
    //    isPermission = "hide";
    //}
    if (IsDeleted == "true") // For Deleted Provider enrollement

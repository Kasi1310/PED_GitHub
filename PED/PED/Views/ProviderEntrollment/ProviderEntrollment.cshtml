        function SaveUpdateProviderEntrollment() {

            var GetId = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.ID)').val();
            GetId = (GetId == "" ? 0 : GetId);

            var GetCompanyId = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.CompanyId)').val();
            var GetDescription = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.Description)').val();
            var GetContactName = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.ContactName)').val();
            var GetContactPhone = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.ContactPhone)').val();

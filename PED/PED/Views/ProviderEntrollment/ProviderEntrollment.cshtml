        function DeleteProviderEntrollment(RID) {
            $("#alertsuccess").hide();
            $('#alertinfo').hide();
            swal({
                title: "Are you sure?",
                text: "You will not be able to recover this detail!",
                type: "error",
                showCancelButton: true,
                confirmButtonClass: 'btn-danger',
                confirmButtonText: 'Yes, delete it!'
            },
            function (isConfirm) {
                if (isConfirm) {
                    var url = "@Url.Action("DeleteProviderEntrollment", "ProviderEntrollment")";
                    var jsonData = { ClientID: RID };
                    AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                        if (resp.message == "Failed") {
                            $('#alertinfo').show();
                            setTimeout(function () {
                                $('#alertinfo').hide();
                                $('#alertinfo').removeClass('show');
                            }, 2000);
                            location.href = $('#hrfProviderEntrollment').val();
                        }
                        else {
                            $('#alertinfo').hide();
                            $('#divResourceList').html(resp);
                            ClearForm();
                            location.href = $('#hrfProviderEntrollment').val();
                        }
                    });
                }
                else {
                    return false;
                }
            });
        };


    <script type="text/javascript">
        $('#btnNotesAdd').live('click', function () {
            ClearNotes();

            $('#divNotesForm').addClass('show');
            $('#divNotesForm').removeClass('hide');
        });

        $('#btnPENotesInsert').live('click', function () {
            $('#@Html.IdFor(m => m.PENotes.Notes)').attr("data-parsley-required", true);

            var validationresult = $('#PENotesfrm').parsley().validate();

            if (validationresult) {

                 var GetId = $('#@Html.IdFor(m => m.PENotes.Id)').val();
                GetId = GetId == "" ? 0 : GetId;

                var url = "@Url.Action("SavePENotes", "ProviderEntrollment")";

                var formData = new FormData();
                formData.append('Id', GetId);
                formData.append('ClientId', $('#hrfClientId').val());
                formData.append('Notes', $('#@Html.IdFor(m => m.PENotes.Notes)').val());

                $.ajax({
                    url: url,
                    type: "POST",
                    contentType: false, // Not to set any content header
                    processData: false, // Not to process data
                    data: formData,
                    success: function (result) {
                        PENotesDatatable();
                        
                        ClearNotes();
                    },
                    error: function (req, status, error) {
                        console.log(error);
                    }
                });
            }
        });

        function LoadPENotesList() {

            $('#tblNotes').DataTable({
                searching: true,
                'aoColumnDefs': [{
                    'bSortable': false,
                    'aTargets': [-1]
                }],
                "columns": [
                     { "width": "50%" },
                     { "width": "20%" },
                     { "width": "20%" },
                     { "width": "10%" }
                ],
            
                "order": [ 3, 'desc' ]
            });
        }

        function PENotesDatatable() {
            var Id = $('#hrfClientId').val();

            var url = "@Url.Action("PENotesList", "ProviderEntrollment")";
            var jsonData = {ClientId: $('#hrfClientId').val()};
            AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                $('#divPENotes').html(resp);

            });

            $('#divNotesForm').removeClass('show');
            $('#divNotesForm').addClass('hide');

        }

         function EditPENotes(NotesID,Notes) {
            $('#@Html.IdFor(m => m.PENotes.Id)').val(NotesID);
            $('#@Html.IdFor(m => m.PENotes.Notes)').val(Notes);

            $('#divNotesForm').addClass('show');
            $('#divNotesForm').removeClass('hide');
            $("#btnPENotesInsert").prop('value', 'Update');
        }

        function ConfirmPENotesDelete(NotesID) {
            var response = swal({
                title: "Are you sure?",
                text: "You will not be able to recover this detail!",
                type: "error",
                showCancelButton: true,
                confirmButtonClass: 'btn-danger',
                confirmButtonText: 'Yes, delete it!'
            },
            function (isConfirm) {
                if (isConfirm) {
                    var url = "@Url.Action("DeletePENotes", "ProviderEntrollment")";
                    var jsonData = { Id: NotesID };
                    AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                        PENotesDatatable();
                        ClearNotes();
                    });
                }
                else {
                    return false;
                }
            });
        }

        function ClearNotes() {
            $('#@Html.IdFor(m => m.PENotes.Id)').val("0");
            $('#@Html.IdFor(m => m.PENotes.Notes)').val("");

            $("#btnPENotesInsert").prop('value', 'Add');

            $('#divNotesForm').addClass('hide');
            $('#divNotesForm').removeClass('show');
        }

    </script>
    

            function PEChkListSendMailUpdateStatusAllocatedTo() {

                var url = "@Url.Action("PEChkListSendMailUpdateStatusAllocatedTo", "ProviderEntrollment")";

                var formData = new FormData();
                formData.append('ClientID', $('#hrfClientId').val());
                formData.append('MailFor', $('#hdnMailFor').val()); //Taskname
                formData.append('CheckListFor', $('#hdnCheckListFor').val());//hdnChkListStatus
                formData.append('Status', CheckListForAllocatedTo);
                formData.append('ChecklistStatus', $('#hdnChkListStatus').val());
                formData.append('PESinglePUID', $('#hdnPESinglePUID').val());
                formData.append('TaskValueAllocatedTo', $('#ddlTaskValueAllocatedTo option:selected').val());

                $.ajax({
                    url: url,
                    type: "POST",
                    contentType: false, // Not to set any content header
                    processData: false, // Not to process data
                    data: formData,
                        success: function (result) {
                            //$('#PECheckListEmailForm').modal('hide');
                            SavePEDetails(); // to save other fields details.

                    },
                    error: function (req, status, error) {
                        console.log(error);
                    }
                });
}

    <script type="text/javascript">
        $('#btnSendDocuments').live('click', function () {
            var isChecked = false;
            var attachement = "";

            var FileNames = "";

            // Iterate over all checkboxes in the table
            dtTblList = $('#tblPEDocumentsList').DataTable();
            dtTblList.$('input[type="checkbox"]').each(function () {
                // If checkbox is checked

                if (this.checked) {
                    isChecked = true;
                    var row = dtTblList.row($(this).parents('tr'));
                    var tdElements = $('td', row.node());

                    var view = '@Html.ActionLink("Doc*", "ViewPEDetailsFile", "ProviderEntrollment", new { fileName = "FN**" })';
                    view = view.replace('FN**', escape(tdElements.eq(2).text())).replace('Doc*', tdElements.eq(2).text())

                    attachement = attachement + view + "<br /><br />";

                    FileNames = FileNames + tdElements.eq(2).text() + ",";

                    //alert(this.value);
                }
            });

            if (!isChecked) {
                document.getElementById("lblDocumentError").innerHTML = "Select one document";
                return false;
            }
            else {
                document.getElementById("divAttachements").innerHTML = attachement;
                $('#CEmailForm').modal('show');
                

                $('#hrfMailAttachment').val(FileNames);
            }
        });


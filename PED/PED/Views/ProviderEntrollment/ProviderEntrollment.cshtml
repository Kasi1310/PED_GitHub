            var GetPayToName = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.PayToName)').val();
            var GetPayToAddressLine1 = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.PayToAddressLine1)').val();
            var GetPayToAddressLine2 = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.PayToAddressLine2)').val();
            var GetPayToCityId = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.PayToCityId)').val();
            var GetPayToStateId = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.PayToStateId)').val();
            var GetPayToZipCode = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.PayToZipCode)').val();
            var GetBillingProviderName = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.BillingProviderName)').val();
            var GetBillingProviderAddressLine1 = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.BillingProviderAddressLine1)').val();
            var GetBillingProviderAddressLine2 = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.BillingProviderAddressLine2)').val();
            var GetBillingProviderCityId = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.BillingProviderCityId)').val();
            var GetBillingProviderStateId = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.BillingProviderStateId)').val();
            var GetBillingProviderZipCode = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.BillingProviderZipCode)').val();
            var GetLastDOS = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.LastDOS)').val();
            var GetContractEndDate = $('#@Html.IdFor(m => m.ProviderEntrollmentDetails.ContractEndDate)').val();


            var ProviderEntrollmentDetails = JSON.stringify({
                Id: GetId,
                CompanyId: GetCompanyId,
                Description: GetDescription,
                ContactName: GetContactName,
                ContactPhone: GetContactPhone,
                NPINumber: GetNPINumber,
                TaxID: GetTaxID,
                CollectionsCompanyName: GetCollectionsCompanyName,
                PayToName: GetPayToName,
                PayToAddressLine1: GetPayToAddressLine1,
                PayToAddressLine2: GetPayToAddressLine2,
                PayToCityId: GetPayToCityId,
                PayToStateId: GetPayToStateId,
                PayToZipCode: GetPayToZipCode,
                BillingProviderName: GetBillingProviderName,
                BillingProviderAddressLine1: GetBillingProviderAddressLine1,
                BillingProviderAddressLine2: GetBillingProviderAddressLine2,
                BillingProviderCityId: GetBillingProviderCityId,
                BillingProviderStateId: GetBillingProviderStateId,
                BillingProviderZipCode: GetBillingProviderZipCode,
                LastDOS: GetLastDOS,
                ContractEndDate: GetContractEndDate
            });
            var url = "@Url.Action("SaveProviderEntrollment", "ProviderEntrollment")";
            var jsonData = ProviderEntrollmentDetails;

            AjaxRequestJsonPostContent(url, jsonData, function (resp, status, req) {
                $('#divProviderEntrollmentList').html(resp);
                $('.collapse').hide();
                $('#btnBillingProviderSubmit').val('Submit');
                $('#alertsuccess').show();
                setTimeout(function () {
                    $('#alertsuccess').hide();
                    $('#alertsuccess').removeClass('show');
                }, 2000);
                $('#expandcollapse').find('i').removeClass('fa-minus').addClass('fa-plus');
                $('#ProviderEntrollmentfrm').parsley().destroy();
                ClearForm();
                LoadProviderEntrollmentList();
               // location.href = $('#hrfProviderEntrollment').val();

            });
        }


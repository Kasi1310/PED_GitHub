                    AddressLine1: GetAddressLine1,
                    AddressLine2: GetAddressLine2,
                    CityId: GetCityId,
                    StateId: GetStateId,
                    ZipCode: GetZipCode,
                    RoutingNumber: GetRoutingNumber,
                    AccountNumber: GetAccountNumber
                    
                });
                var url = "@Url.Action("SavePEClientsBankInfo", "ProviderEntrollment")";
                var jsonData = PEContacts;
                AjaxRequestJsonPostContent(url, jsonData, function (resp, status, req) {
                    PEClientsBankInfoDatatable();
                    ClearClientsBankInfo();
                });
            }
        });

        function PEClientsBankInfoDatatable() {
            var Id = $('#hrfClientId').val();

            var url = "@Url.Action("PEClientsBankInfoList", "ProviderEntrollment")";
            var jsonData = Id;
            AjaxRequestJsonPostContent(url, jsonData, function (resp, status, req) {
                $('#divPEClientsBankInfo').html(resp);
                

                $('.DateMask').datepicker({
                    format: 'mm/dd/yyyy',
                    autoclose: true,
                    orientation: 'bottom left'
                });

            });


            $('#divClientsBankInfoForm').removeClass('show');
            $('#divClientsBankInfoForm').addClass('hide');
        }
          function EditPEClientsBankInfo(ClientsBankInfoID) {

            var url = "@Url.Action("EditPEClientsBankInfo", "ProviderEntrollment")";
            var formData = new FormData();
            formData.append('Id', ClientsBankInfoID);

            $.ajax({
                url: url,
                type: "POST",
                contentType: false,
                processData: false,
                data: formData,
                success: function (result) {
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.Id)').val(result.data["id"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.ClientDetailsID)').val(result.data["clientDetailsID"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.BankName)').val(result.data["bankName"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.AccountType)').val(result.data["accountType"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.BankCategory)').val(result.data["bankCategory"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.EffectiveDate)').val(result.data["effectiveDate"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.EndDate)').val(result.data["endDate"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.AddressLine1)').val(result.data["addressLine1"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.AddressLine2)').val(result.data["addressLine2"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)').val(result.data["cityId"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.StateId)').val(result.data["stateId"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.ZipCode)').val(result.data["zipCode"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.RoutingNumber)').val(result.data["routingNumber"]);
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.AccountNumber)').val(result.data["accountNumber"]);


                    $('#hfClientsBankInfoStateId').val(result.data["stateId"]);
                    $('#hfClientsBankInfoCityId').val(result.data["cityId"]);
                    SetClientsBankInfoCity();

                    $('#divClientsBankInfoForm').addClass('show');
                    $('#divClientsBankInfoForm').removeClass('hide');
                    $("#btnPEClientsBankInfoInsert").prop('value', 'Update');
                },
                error: function (err) {
                }
            });
        }
        function SetClientsBankInfoCity() {
            var StateId = $('#hfClientsBankInfoStateId').val();
            var CityId = $('#hfClientsBankInfoCityId').val();
            var url = '@Url.Action("GetCity", "Admin")';
            var jsonData = { StateId: StateId };


            AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                $($('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)')).get(0).options.length = 0;
                $("<option value = >Select City</option>").appendTo($('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)'));
                $.each(resp, function (index) {
                    $('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)').append($("<option></option>").attr('value', this.id).text(this.value));
                });
                if (CityId != 'undefined' && CityId != null && CityId != '') {
                    $($('#@Html.IdFor(m => m.PEClientsBankInfo.CityId)')).val(CityId);
                }
            });
        }
         function ConfirmPEClientsBankInfoDelete(ClientsBankInfoID) {
            var response = swal({
                title: "Are you sure?",
                text: "You will not be able to recover this detail!",
                type: "error",
                showCancelButton: true,
                confirmButtonClass: 'btn-danger',
                confirmButtonText: 'Yes, delete it!'
            },
            function (isConfirm) {
                if (isConfirm) {
                    var url = "@Url.Action("DeletePEClientsBankInfo", "ProviderEntrollment")";
                    var jsonData = { Id: ClientsBankInfoID };
                    AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                        PEClientsBankInfoDatatable();
                        ClearClientsBankInfo();
                    });
                }
                else {
                    return false;
                }
            });
        }
        $("#PEClientsBankInfo_EndDate").datepicker({
            dateFormat: "mm/dd/yy"
        });
          $("#PEClientsBankInfo_EffectiveDate").datepicker({
            dateFormat: "mm/dd/yy"
        });


         $('#btnPEClientsBankInfoFileUpload').live('click', function () {
            var fileInput = $('#ClientsBankInfoFileUpload')[0];

            if (fileInput.files.length === 0) {
                alert("Please select a file to upload.");
                return;
            }

            var formData = new FormData();
            formData.append("ClientsBankInfoFileUpload", fileInput.files[0]);

            // Optional: add other data
            var clientId = $('#hrfClientId').val();
            formData.append("ClientDetailsID", clientId);

            $.ajax({
                url: '@Url.Action("UploadPEClientsBankInfoFile", "ProviderEntrollment")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                    beforeSend: function () {
                    ShowOverlay();   // Show loader
                    },

                   success: function (response) {
                    swal({
                        icon: 'success',
                        title: 'Success',
                        text: 'File uploaded successfully!',
                        confirmButtonColor: '#3085d6',
                        confirmButtonText: 'OK'
                    });
                },
                error: function (xhr, status, error) {
                    alert("Upload failed: " + error);
                },
                    complete: function () {
                        HideOverlay();// Hide loader (always runs)
                    }
            });
        });
         
        </script>
}

@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}

<form id="PEOtherAddressesListfrm" method="post" class="form-horizontal">
    <div class="row col-12 p-10" id="PEOtherAddresses">
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-12 col-md-12 col-lg-12 p-0">

                    <table id="tblPEOtherAddress" class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>Address Type</th>
                                <th>Address Line 1</th>
                                <th>Address Line 2</th>
                                <th>City</th>
                                <th>State</th>
                                <th>Zip</th>
                                <th>Phone #</th>
                                <th class="@isAdmin">Action</th>
                            </tr>
                        </thead>
                        <tbody>

                            @{ int i = 0;
                                foreach (var item in Model.PEOtherAddressList)
                                {
                                    i++;
                                    <tr id="@item.Id">
                                        @*<td id="tdSno" class="tr1">@i</td>*@
                                        <td class="tr1">@item.AddressType</td>
                                        <td class="tr1">@item.AddressLine1</td>
                                        <td class="tr1">@item.AddressLine2</td>
                                        <td class="tr1">@item.City</td>
                                        <td class="tr1">@item.State</td>
                                        <td class="tr1">@item.ZipCode</td>
                                        <td class="tr1">@item.PhoneNumber</td>
                                        <td class="tr1">
                                            <button id="btnOtherAddressEdit" type="button" Onclick="EditPEOtherAddress('@item.Id','Edit')" title="Edit" class="fa fa-lg fa-edit  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>
                                            <button id="btnOtherAddressDelete" type="button" Onclick="ConfirmPEOtherAddressDelete('@item.Id')" title="Delete" class="fa fa-lg fa-trash-o  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>
                                            <button id="btnOtherAddressCopy" type="button" Onclick="CopyPEOtherAddress('@item.Id')" title="Copy" class="fa fa-lg fa-copy  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>

                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>

                        </tfoot>
                    </table>

                </div>
            </div>
        </div>
    </div>
</form>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    var RoleId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleID");
    var isEnabled = "";

    if (RolePermission == "R")
    {
        isAdmin = "hide";
        isEnabled = "disabled";
    }
}
<form id="PESinglePayerUpdateCheckList" class="form-horizontal">
    <input type="hidden" id="hdnPESinglePUID" value="0" />
    <div class="col-lg-12">
        <div class="form-group" style="margin-bottom: 5px !important;">
            <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="Status">Payer Name</label>
            </div>
            <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="Status">Payer Status</label>
            </div>
            <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="Action">Notify AR</label>
            </div>
            <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="Allocated To">Allocated To</label>
            </div>
            
        </div>
    </div>
    <div class="col-lg-12">
        <div class="form-group" style="margin-bottom: 5px !important;">
            <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                @Html.TextBoxFor(m => m.PESinglePayerUpdateCheckList.TaskName, new { @class = "form-control", @placeholder = "Enter Task Name", })
            </div>
            <div class="col-md-3 col-sm-3 col-lg-3 p-0">
                <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                    <select id="ddlSPUTask" class="form-control clsSPUTask" @isEnabled>
                        <option value="Not Started">Not Started</option>
                        <option value="Request from Client">Request from Client</option>
                        <option value="Waiting on Client">Waiting on Client</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="NA">NA</option>
                    </select>
                    @Html.HiddenFor(m => m.PESinglePayerUpdateCheckList.TaskValue)
                </div>
            </div>
            <div class="col-md-3 col-sm-3 col-lg-3 p-0">
                <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                    <select id="ddlSPUNotifyAR" class="form-control clsSPUPEDAddressUpdate" @isEnabled>
                        <option value="Not Started">Not Started</option>
                        <option value="Completed">Completed</option>
                        <option value="NA">NA</option>
                    </select>
                    @Html.HiddenFor(m => m.PESinglePayerUpdateCheckList.NotifyAR)
                </div>
            </div>
            <div class="col-md-3 col-sm-3 col-lg-3 p-0">
                <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                    <select id="ddlTaskValueAllocatedTo" class="form-control clsTaskValueAllocatedTo" @isEnabled>
                        <option value="Select">Select</option>
                        <option value="AmyKing">AmyKing</option>
                        <option value="BillyWhite">Billy White</option>
                        <option value="PamelaRoysdon">Pamela Roysdon</option>
                    </select>
                    @Html.HiddenFor(m => m.PESinglePayerUpdateCheckList.TaskValueAllocatedTo)
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-12">
        <div class="form-group" style="margin-bottom: 5px !important;">
            
            
        </div>
    </div>
    <div class="col-lg-12">
        <div class="form-group" style="margin-bottom: 5px !important;">
            <div class="col-sm-12 col-md-12 col-lg-12 p-0">
                <table id="tblPESinglePayerList" class="table table-striped table-bordered">
                    <thead>
                        <tr role="row">
                            <th>Payer Name</th>
                            <th>Payer Status</th>
                            <th>Notify AR</th>
                            <th>Allocated To</th>
                            <th class="tr1">Action</th>
                        </tr>
                    </thead>
                    <tbody>

                        @{int i = 0;
                            foreach (var item in Model.ListOfPESinglePayerUpdateCheckList)
                            {
                                i++;
                                <tr role="row" id="@item.Id">
                                    <td class="tr1">@item.TaskName</td>
                                    <td class="tr1">@item.TaskValue</td>
                                    <td class="tr1">@item.NotifyAR</td>
                                    <td class="tr1">@item.TaskValueAllocatedTo</td>
                                    <td class="tr1">
                                        <button id="btnSinglePayerEdit" type="button" Onclick="EditPESinglePayer('@item.Id', '@item.TaskName', '@item.TaskValue', '@item.NotifyAR','@item.TaskValueAllocatedTo')" title="Edit" class="fa fa-lg fa-edit  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>
                                        <button id="btnSinglePayerDelete" type="button" Onclick="ConfirmPESinglePayerDelete('@item.Id')" title="Delete" class="fa fa-lg fa-trash-o  text-inverse form-control1 p-l-0 p-r-0 @isAdmin" style="border:none; background-color:transparent"></button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot>

                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</form>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}


<form id="PEEFTFormfrm" method="post" class="form-horizontal">
    <div class="row col-12 p-10" id="PEEFTForm">
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">                
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="PayerName">Payer Name<span style="color:red">*</span></label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="BankType">Bank Type</label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="EffectiveDate">Comments</label>
                </div>
                
            </div>
        </div>
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" data-parsley-validate="true">
                        @Html.HiddenFor(m => m.PEEFT.Id)
                        @Html.TextBoxFor(m => m.PEEFT.EFTPayerName, new { @class = "form-control", @placeholder = "Enter Payer Name" })
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" >
                        <select id="ddlBankType" class="form-control" >
                            <option value="0">Selected</option>
                            <option value="1">Medicount Bank</option>
                            <option value="2">Client’s Bank</option>                            
                        </select>
                        @Html.HiddenFor(m => m.PEEFT.EFTBankType)
                    </div>
                </div>
               
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" >
                        @Html.TextBoxFor(m => m.PEEFT.EFTComments, new { @class = "form-control", @placeholder = "Enter Comments" })

                    </div>
                </div>
              
                <div class="col-sm-1 col-md-1 col-lg-1 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        <input type="button" id="btnPEEFTInsert" class="btn btn-sm btn-success m-r-5" value="Add" />
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-12" id="EFTBulkUpload">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="eftbulkUpload">EFT Bulk uplaod</label>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-12" id="EFTBulkUpload">
            <div class="form-group" style="margin-bottom: 5px !important;">
                     <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                        <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                            <input type="file" id="EFTFileUpload" name="EFTFileUpload" class="form-control" />
                        </div>
                    </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        <input type="button" id="btnPEEFTFileUpload" class="btn btn-sm btn-success m-r-5" value="Upload" />
                    </div>
                </div>
            </div>
        </div>
       
    </div>

</form>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}

<form id="PEContractsFormfrm" method="post" class="form-horizontal">

    <div class="row col-12 p-10" id="PEContractForm">
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="InsuranceName">Insurance Name<span style="color:red">*</span></label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="EffectiveDate">Info</label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="EffectiveDate">Effective Date</label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="LastRevalidateDate">Last Revalidation Date</label>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        @Html.HiddenFor(m => m.PEInsuranceContracts.Id)
                        @Html.HiddenFor(m => m.PEInsuranceContracts.ClientDetailsID)
                        @Html.DropDownListFor(m => m.PEInsuranceContracts.InsuranceContractId, new SelectList(Model.InsuranceContractList, "Id", "Name"), "Select Insurance Name", new { @class = "form-control InsuranceContractList" })
                    </div>
                </div>

                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        @Html.TextBoxFor(m => m.PEInsuranceContracts.Info, new { @class = "form-control", @placeholder = "Enter Info", })
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 controls input-daterange datepicker-autoClose input-group">
                        @Html.TextBoxFor(m => m.PEInsuranceContracts.EffectiveDate, new { @class = "form-control DateMask datepicker-autoClose", @placeholder = "Enter Effective Date", })
                        <span class="input-group-addon">
                            <span class="glyphicon glyphicon-calendar"></span>
                        </span>
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 controls input-daterange datepicker-autoClose input-group">
                        @Html.TextBoxFor(m => m.PEInsuranceContracts.LastRevalidateDate, new { @class = "form-control DateMask datepicker-autoClose", @placeholder = "Enter Last Revalidate Date", })
                        <span class="input-group-addon">
                            <span class="glyphicon glyphicon-calendar"></span>
                        </span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="NextUpdateDue">Next Revalidation Date<span id="spnNextRevalidationDate" style="color:red">*</span></label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="TermedDate">Termed Date</label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="ProviderNo">Provider #</label>
                </div>
                @*<div class="col-sm-3 col-md-3 col-lg-3 p-0">
            <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="GroupNo">Group #</label>
        </div>*@
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="Active">Active</label>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">

                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 controls input-daterange datepicker-autoClose input-group">
                        @Html.TextBoxFor(m => m.PEInsuranceContracts.NextUpdateDue, new { @class = "form-control DateMask datepicker-autoClose", @placeholder = "Enter Next Update Due", })
                        <span class="input-group-addon">
                            <span class="glyphicon glyphicon-calendar"></span>
                        </span>
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 controls input-daterange datepicker-autoClose input-group">
                        @Html.TextBoxFor(m => m.PEInsuranceContracts.TermedDate, new { @class = "form-control DateMask datepicker-autoClose", @placeholder = "Enter Termed Date", })
                        <span class="input-group-addon">
                            <span class="glyphicon glyphicon-calendar"></span>
                        </span>
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        @Html.TextBoxFor(m => m.PEInsuranceContracts.ProviderNo, new { @class = "form-control", @placeholder = "Enter Provider #", })
                    </div>
                </div>
                @*<div class="col-sm-3 col-md-3 col-lg-3 p-0">
            <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                @Html.TextBoxFor(m => m.PEInsuranceContracts.GroupNo, new { @class = "form-control", @placeholder = "Enter Group #", })
            </div>
        </div>*@

                <div class="col-sm-2 col-md-2 col-lg-2 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        <select id="ddlActive" class="form-control" onchange="EnableMandatory()">
                            <option value="1" selected="selected">Yes</option>
                            <option value="0">No</option>
                            <option value="2">Pending</option>
                            <option value="3">RefusedEnrollment</option>
                        </select>
                        @Html.HiddenFor(m => m.PEInsuranceContracts.Active)
                    </div>
                </div>
                <div class="col-sm-1 col-md-1 col-lg-1 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        <input type="button" id="btnPEContractInsert" class="btn btn-sm btn-success m-r-5" value="Add" />
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script type="text/javascript">
        function EnableMandatory() {
            if (document.getElementById('ddlActive').value == "1") {

                $('#spnNextRevalidationDate').show();
            }
            else {
                $('#spnNextRevalidationDate').hide();
            }
        }
    </script>
</form>
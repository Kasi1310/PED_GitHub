@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    var IsDeleted = HttpContextAccessor.HttpContext.Session.Get<string>("SessionPEDetailsDeleted");

    if (RolePermission == "R" || IsDeleted == "true")
    {
        isAdmin = "hide";
    }
}

<form id="PEDocumentsfrm" method="post" class="form-horizontal">
    <div class="panel panel-inverse col-lg-12" data-sortable-id="form-validation-1">
        <div class="panel-heading">
            <h6 class="panel-title" id="changeteam">Documents</h6>
        </div>
        <div class="panel-body panel-form p-t-15 m-t-10">
            <div class="row col-12 p-10" id="CompanyDetails">
                <div class="@isAdmin">
                    <div class="col-lg-12 form-group" style="margin-bottom: 5px !important;">
                        <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                            <input type="button" id="btnDocumentsAdd" class="btn btn-sm btn-default m-r-5" value="Add Document" />
                            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                            <input type="button" id="btnSendDocuments" class="btn btn-sm btn-success m-r-5" value="Send Documents" />
                        </div>
                    </div>
                    <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                        <label id="lblDocumentError" style="color:red;"></label>
                    </div>
                </div>
            </div> <div class="col-lg-12 hide" id="divDocumentsForm">
                @{ Html.RenderPartial("_PEDocumentsForm", Model); }
            </div>
            <div class="col-lg-12" id="divDocumentsList">
                @{ Html.RenderPartial("_PEDocumentsList", Model); }
            </div>
        </div>
    </div>
</form>
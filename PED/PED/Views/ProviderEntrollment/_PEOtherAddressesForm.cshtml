@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.ProviderEntrollment;
@model ProviderEntrollment
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}


<input type="hidden" id="hfOAStateId" value="0" />
<input type="hidden" id="hfOACityId" value="0" />
<form id="PEOtherAddressesFormfrm" method="post" class="form-horizontal">

    <div class="row col-12 p-10" id="PEOtherAddresses">
        <div class="col-lg-12">
            <button id="btnOtherAddressPaste" type="button" Onclick="PastePEOtherAddress()"
                    title="Paste" class="fa fa-lg fa-paste  text-inverse form-control1 p-l-0 p-r-0 @isAdmin"
                    style="border:none; background-color:transparent"></button>
            <label>Paste</label>
        </div>
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="InsuranceName">Address Type<span style="color:red">*</span></label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="EffectiveDate">Address Line 1<span style="color:red">*</span></label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="TermedDate">Address Line 2</label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="ProviderNo">State<span style="color:red">*</span></label>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" data-parsley-validate="true">
                        @Html.HiddenFor(m => m.PEOtherAddress.Id)
                        @Html.DropDownListFor(m => m.PEOtherAddress.AddressTypeID, new SelectList(Model.PEAddressTypeList, "Id", "Value"), "Select Address Type", new { @class = "form-control" })
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" data-parsley-validate="true">
                        @Html.TextBoxFor(m => m.PEOtherAddress.AddressLine1, new { @class = "form-control", @placeholder = "Enter Address Line 1" })
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" data-parsley-validate="true">
                        @Html.TextBoxFor(m => m.PEOtherAddress.AddressLine2, new { @class = "form-control", @placeholder = "Enter Address Line 2" })
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" data-parsley-validate="true">
                        @Html.DropDownListFor(m => m.PEOtherAddress.StateId, new SelectList(Model.StatesList, "Id", "Value"), "Select State", new { @class = "form-control OtherAddressStatesList" })
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="City">City<span style="color:red">*</span></label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="ZipCode">Zip Code<span style="color:red">*</span></label>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <label class="control-label col-md-11 col-sm-11" style="text-align:left !important;padding-left:2px !important" for="PhoneNumebr">Phone #</label>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="form-group" style="margin-bottom: 5px !important;">

                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" data-parsley-validate="true">
                        @Html.DropDownListFor(m => m.PEOtherAddress.CityId, new SelectList(Model.CitiesList, "Id", "Value"), "Select City", new { @class = "form-control OtherAddressCitiesList" })
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" data-parsley-validate="true">
                        @Html.TextBoxFor(m => m.PEOtherAddress.ZipCode, new { @class = "form-control", @placeholder = "Enter Zip Code" })
                    </div>
                </div>
                <div class="col-sm-3 col-md-3 col-lg-3 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls" data-parsley-validate="true">
                        @Html.TextBoxFor(m => m.PEOtherAddress.PhoneNumber, new { @class = "form-control", @placeholder = "Enter Phone #" })
                    </div>
                </div>
                <div class="col-sm-1 col-md-1 col-lg-1 p-0">
                    <div class="col-md-11 col-sm-11 col-lg-11 p-0 controls">
                        <input type="button" id="btnPEOtherAddressesInsert" class="btn btn-sm btn-success m-r-5" value="Add" />
                    </div>
                </div>
            </div>
        </div>
    </div>

</form>
        function Dashboarddata(Dashboardname)
        {
            var GetBoxname=Dashboardname;
            //alert(GetBoxname);
            $.ajax({
                url: '@Url.Content("~/Home/DownloadDashboardData")',
                type: "POST",
                datatype: "json",
                data:{
                    BoxName: $("#hrfBoxId").val()
                },
                success:function(data){
                    const a = document.createElement('a');
                    a.style.display = 'none';
                    a.href = data;
                    a.download = 'DashboardData.xlsx';
                    document.body.appendChild(a);
                    a.click();
                    console.log(data);
                },
                error: function (result) {
                    console.log(result);
                }
            });


         }






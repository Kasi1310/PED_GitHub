@using WiseX.ViewModels.Home
@model HomeViewModel
@{
    ViewData["Title"] = "Index";
}
@using Microsoft.Extensions.Options;
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject IOptions<AppSettings> AppSettingsOptions
@using WiseX.Helpers;

@{
    string CurrentProjectName = string.Empty;
    string isAdmin = string.Empty;
    var numCount = "";
    var message = HttpContextAccessor.HttpContext.Session.Get<List<NotificationDetails>>("my-message");
    var Changeproject = HttpContextAccessor.HttpContext.Session.Get<List<UserProjectRole>>("Changeproject");
    var RoleId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleID");
    //var project = HttpContextAccessor.HttpContext.Session.Get<string>("SessionProjectName");
    var NotificationCount = HttpContextAccessor.HttpContext.Session.Get<string>("NotificationCount");
    var RoleAccess = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess").ToString();
   
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }

}
<!-- begin #content -->
<input type="hidden" id="hrfBoxId" value="" />
<input type="hidden" id="hfRoleAccess" value="@RoleAccess" />
<div id="content" class="content">
    <!-- begin breadcrumb -->
    <ol class="breadcrumb pull-right">
        <li><a href="javascript:;">Home</a></li>
        <li><a href="javascript:;">Dashboard</a></li>
        <li class="active">Dashboard</li>
    </ol>
    <!-- end breadcrumb -->
    <!-- begin page-header -->
    <!-- end page-header -->
    <!-- begin row -->
    <div class="row @isAdmin" id="divBoxes">
        @{ Html.RenderPartial("_Boxes", Model); }
    </div>
    <div class="rowList hide" id="divBoxesList">
        @{ Html.RenderPartial("_BoxesList", Model);}
    </div>
    <div class="rowList hide" id="divPECredentialingLicenseBoxesList">
        @{ Html.RenderPartial("_PECredentialingLicenseBoxesList", Model);}
    </div>
    <div class="rowList hide" id="divPEContractBoxesList">
        @{ Html.RenderPartial("_PEContractBoxesList", Model);}
    </div>
    <div class="rowList hide" id="divPECheckListBoxes">
        @{ Html.RenderPartial("_PECheckListBoxes", Model);}
    </div>
    <div id="divBoxesTaskDetails">
        @{ Html.RenderPartial("_BoxesTaskDetails", Model);}
    </div>
    <div class="rowList hide" id="divPECheckListBoxesForAllocatedUser">
        @{
            Html.RenderPartial("_PECheckListForAllocatedUser", Model);
        }
    </div>
    <!-- end row -->
</div>
<div id="divNotificationForm">
    @{await Html.RenderPartialAsync("_NotificationPupupForm", Model); }
</div>
<!-- end #content -->

@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@model List<WiseX.ViewModels.Admin.Roles>
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}
<div class="panel panel-inverse" data-sortable-id="form-validation-1">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:;" class="btn btn-xs btn-icon btn-circle btn-default collapsed" id="expandcollapse" data-click="panel-collapse" data-original-title="" title="" data-init="true"><i class="fa fa-minus"></i></a>
        </div>
        <h4 class="panel-title">Roles List</h4>
    </div>
    <div class="panel-body">
        <div class="panel-body">
            <table id="rolesTable" class="table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Sno</th>
                        <th>Roles</th>
                        <th>Permissions</th>
                        <th>Active</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{int i = 0;
                        foreach (var item in Model)
                        {
                            i++;
                            <tr>
                                <td id="txtSno">@i</td>
                                <td id="roletxt">@item.Name</td>
                                <td id="Permissiontxt">@item.PermissionsType</td>
                                <td id="acttxt">@item.Status</td>
                                <td>

                                    @if (item.IsDeletable == 1)
                                    {
                                        <button id="btnedit" onclick="EditRole('@item.Id')" title="Edit" class="fa fa-lg fa-edit @isAdmin text-inverse form-control1" style="border:none; background-color:transparent"></button>
                                        @if (item.Status != "No")
                                        {
                                            <button id="btnDelete" Onclick="ConfirmDelete('@item.Id')" title="Delete" class="fa fa-lg fa-trash-o @isAdmin text-inverse form-control1 p-l-0 p-r-0" style="border:none; background-color:transparent"></button>

                                        }
                                    }
                                    else
                                    {
                                        <i class="fa fa-lg fa-lock @isAdmin" title="You cannot delete this role"></i>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

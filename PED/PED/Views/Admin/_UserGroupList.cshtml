@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.Admin;
@model UserGroup
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    var RoleId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleID");

    if (RoleId == "30133577-ba4d-4d74-8c17-575c99f6cc01")//Provider Enrollment Full Access
    {
        isAdmin = "hide";
    }
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}
<div class="panel panel-inverse" data-sortable-id="form-validation-1">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:;" class="btn btn-xs btn-icon btn-circle btn-default collapsed" id="expandcollapse" 
               data-click="panel-collapse" data-original-title="" title="" data-init="true"><i class="fa fa-minus"></i></a>
        </div>
        <h4 class="panel-title">User Group List</h4>
    </div>
    <div class="panel-body">
        <table id="tblUserGroupList" class="table table-striped table-bordered table-hover">
            <thead>
                <tr>
                    <th>Group Name</th>
                    <th>Name</th>
                    <th>Active</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.UserGroupList)
                {
                <tr>
                    <td>@item.GroupName</td>
                    <td>@item.UserName</td>
                    <td>@item.Active</td>
                    <td class="tr1">
                        <button id="btnedit" onclick="EditUserGroup('@item.Id')" title="Edit" class="fa fa-lg fa-edit  text-inverse form-control1" style="border:none; background-color:transparent"></button>

                        <button id="btnDelete" Onclick="ConfirmDelete('@item.Id')" title="Delete" class="fa fa-lg fa-trash-o @isAdmin  text-inverse form-control1 p-l-0 p-r-0" style="border:none; background-color:transparent"></button>

                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

    function LoadLengthCalc() {
        $('#ClientsDetails_ContractExpiryDate').on('blur', function () {
            var expStrDate = $.trim($(this).val());
            var renewStrDate = $.trim($(this).closest('#Clientsfrm').find('#ClientsDetails_ContractEffDate').val());
            var expDate;
            //alert(expStrDate + "" + renewStrDate +"");
            if (expStrDate != '' && renewStrDate != '') {
                expDate = new Date(expStrDate);
                var renewDate = new Date(renewStrDate);
                $('#ClientsDetails_ContractLength').val(diff_years(renewDate, expDate));

            }
            if (expStrDate != '') {
                expDate = new Date(expStrDate);
                //var Expirydt = $('.date').val();
                var d = new Date();
                var crntdt = (d.getMonth() + 1) + "/" + d.getDate() + "/" + d.getFullYear();
                if (new Date(expStrDate) >= new Date(crntdt)) {
                    $('#Active').attr('checked', true);
                    $('#InActive').attr('checked', false);
                }

                if (new Date(expStrDate) < new Date(crntdt)) {
                    $('#Active').attr('checked', false);
                    $('#InActive').attr('checked', true);
                }
            }
        });

    }
        //future date active or not
    function ExpiredContractCalc()
    {
        $('.date').change(function () {
            var expStrDate = $.trim($(this).val());
            var renewStrDate = $.trim($(this).closest('#Clientsfrm').find('#ClientsDetails_ContractEffDate').val());

            if (expStrDate != '' && renewStrDate != '') {
                var expDate = new Date(expStrDate);
                var renewDate = new Date(renewStrDate);
                $('#ClientsDetails_ContractLength').val(diff_years(renewDate, expDate));

            }
            //var Expirydt = $('.date').val();
            var d = new Date();
            var crntdt = (d.getMonth() + 1) + "/" + d.getDate() + "/" + d.getFullYear();
            if (new Date(expStrDate) > new Date(crntdt)) {
                $('#Active').attr('checked', true);
                $('#InActive').attr('checked', false);
            }
            if (new Date(expStrDate) < new Date(crntdt)) {
                $('#Active').attr('checked', false);
                $('#InActive').attr('checked', true);
            }
        });

    }
    function diff_years(dt2, dt1) {
        var diff = (dt2.getTime() - dt1.getTime()) / 1000;
        diff /= (60 * 60 * 24);
        return Math.abs(Math.round(diff / 365.25));
    }


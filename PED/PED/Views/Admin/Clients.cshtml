    function AddInsuranceContract()
    {
        var GetDocumentType = $('#@Html.IdFor(m => m.ClientsDetails.DocumentType)').val();
        var GetInsuranceContractID = $('#@Html.IdFor(m => m.ClientsDetails.InsuranceContractID)').val();
        var GetEffectiveDate = $('#@Html.IdFor(m => m.ClientsDetails.EffectiveDate)').val();
        var GetTermedDate = $('#@Html.IdFor(m => m.ClientsDetails.TermedDate)').val();
        var GetReferenceID = $('#hrfInsuranceContractRefID').val() == '' ? 0 : $('#hrfInsuranceContractRefID').val();
        var GetId = $('#@Html.IdFor(m => m.ClientsDetails.InsuranceID)').val();
            GetId = (GetId == "" ? 0 : GetId);
        var ClientsInsuranceContractDetails = JSON.stringify({
            ID: GetId,
            DocumentType: GetDocumentType,
            InsuranceContractID: GetInsuranceContractID,
            EffectiveDate: GetEffectiveDate,
            TermedDate: GetTermedDate,
            RefID: GetReferenceID
        });

        var url = "@Url.Action("AddClientsInsuranceContract", "Admin")";
        var jsonData = ClientsInsuranceContractDetails;
        AjaxRequestJsonPostContent(url, jsonData, function (resp, status, req) {
            if (resp.insuranceContractId > 0) {
                if (window.FormData !== undefined) {
                    ShowOverlay();
                    var formData = new FormData();
                    formData.append('file', $('#InsuranceContractFile')[0].files[0]);
                    formData.append('InsuranceContractRefId', resp.insuranceContractRefId);
                    formData.append('InsuranceContractId', resp.insuranceContractId);
                    var url = "@Url.Action("SaveInsuranceContractFiles", "Admin")";
                    $.ajax({
                        url: url,
                        type: "POST",
                        contentType: false,
                        processData: false,
                        data: formData,
                        success: function (result) {
                            $('#divClientsInsuranceContractListform').html(result);
                            $('#hrfInsuranceContractRefID').val(resp.insuranceContractRefId);
                            ClearInsuranceContract();
                            $('#btnInsuranceContractAdd').val('Add');
                            CancelTeam();
                            //alert("Contract added successfully!");
                            HideOverlay();
                        },
                        error: function (err) {
                        }
                    });
                }
            }
        });
    }

    function ClearInsuranceContract() {
        $('#@Html.IdFor(m => m.ClientsDetails.InsuranceID)').val(0);
        $('#@Html.IdFor(m => m.ClientsDetails.DocumentType)').val(0);
        $('#@Html.IdFor(m => m.ClientsDetails.InsuranceContractID)').val(0);
        $('#@Html.IdFor(m => m.ClientsDetails.EffectiveDate)').val('');
        $('#@Html.IdFor(m => m.ClientsDetails.TermedDate)').val('');
        $('#InsuranceContractFile').val('');
    }


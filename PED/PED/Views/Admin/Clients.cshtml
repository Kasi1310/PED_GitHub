        function Transport()
        {
            $("#Transport").change(function () {
                var ischecked = $(this).is(':checked');
                if (!ischecked)
                {
                    $('#NonTransportCharges').addClass("hide");
                    $('.TransportCharges').val("");
                    $('#@Html.IdFor(m => m.ClientsDetails.TransportCharges)').attr("data-parsley-required", false);
                }
            });

            $('#Transport').on('click', function () {
                $('#TreatNoTransport').attr('checked', false);
                var GetTransport = $('#Transport:checked').val();
                if (GetTransport == "true")
                {
                    $('#NonTransportCharges').removeClass("hide");
                    $('#@Html.IdFor(m => m.ClientsDetails.TransportCharges)').attr("data-parsley-required", true);
                }
            });
            $('#TreatNoTransport').on('click', function () {
                $('#Transport').attr('checked', false);
                var GetTransport = $('#TreatNoTransport:checked').val();
                if (GetTransport == "true") {
                    $('#NonTransportCharges').addClass("hide");
                    $('.TransportCharges').val("");
                    $('#@Html.IdFor(m => m.ClientsDetails.TransportCharges)').attr("data-parsley-required", false);
                }

            });
        }


    </script>
   
    

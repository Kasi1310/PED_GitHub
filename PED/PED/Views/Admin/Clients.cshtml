            $('#OtherDocumentfile').attr('data-parsley-required', 'false');
            $('.mandatory').hide();
            InitControls();
            CancelTeam();
            SetCity();
            Transport();
            ScrollToTop();
            LoadLengthCalc();
            ExpiredContractCalc();
            FeesChangeCalc();
        });
    }


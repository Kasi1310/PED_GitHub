    function LoadBulkUploadClientsList()
        {
            table = $('#tblBulkUploadClients').DataTable({
                searching: true,
                'aoColumnDefs': [{
                    'bSortable': false,
                    'aTargets': [0]
                }],
                "columnDefs": [
                        { "type": "num", "targets": 1 }
                ],
                "order": [ 1, 'desc' ],
                dom: 'l<"toolbar">frtip'
            });

            // Handle click on "Select all" control
            $('#checkAlle').on('click', function () {
                // Check/uncheck all checkboxes in the table
                var rows = table.rows({ 'search': 'applied' }).nodes();
                $('input[type="checkbox"]:not(":disabled")', rows).prop('checked', this.checked);
            });

            // Handle click on checkbox to set state of "Select all" control
            $('#tblBulkUploadClients tbody').on('change', 'input[type="checkbox"]', function () {
                // If checkbox is not checked
                if (!this.checked) {
                    var el = $('#checkAlle').get(0);
                    // If "Select all" control is checked and has 'indeterminate' property
                    if (el && el.checked && ('indeterminate' in el)) {
                        // Set visual state of "Select all" control
                        // as 'indeterminate'
                        el.indeterminate = true;
                    }
                }
            });
        }*@

    function CitiesOnchange()
    {
        $('.CitiesList').live('change', function () {
            var url = '@Url.Action("GetState", "Admin")';
            var CityId = $(this).val();
            var jsonData = { CityId: CityId };
            AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                $($('#@Html.IdFor(m => m.ClientsDetails.StateId)')).get(0).options.length = 0;
                $("<option value = >Select a State</option>").appendTo($('#@Html.IdFor(m => m.ClientsDetails.StateId)'));
                $.each(resp, function (index) {
                    $('#@Html.IdFor(m => m.ClientsDetails.StateId)').append($("<option></option>").attr('value', this.id).text(this.value));
                });
            });

        });
    }
        function StatesOnchange() {
            $('.StatesList').live('change', function () {
                var StateId = $(this).val();
                $('#hfStateId').val(StateId);
                SetCity();
            });
        }

        function SetCity() {
            var StateId = $('#hfStateId').val();
            var CityId = $('#hfCityId').val();
            var url = '@Url.Action("GetCity", "Admin")';
            var jsonData = { StateId: StateId };


            AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                $($('#@Html.IdFor(m => m.ClientsDetails.CityId)')).get(0).options.length = 0;
                $("<option value = >Select a City</option>").appendTo($('#@Html.IdFor(m => m.ClientsDetails.CityId)'));
                $.each(resp, function (index) {
                    $('#@Html.IdFor(m => m.ClientsDetails.CityId)').append($("<option></option>").attr('value', this.id).text(this.value));
                });
                if (CityId != 'undefined' && CityId != null && CityId != '') {
                    $($('#@Html.IdFor(m => m.ClientsDetails.CityId)')).val(CityId);
                }
            });
        }

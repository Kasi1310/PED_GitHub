    function ddlClientStatus()
    {
        var clientStatusId=$("#DDLStatusID").val(); 
        var erId=$("#DDLERId").val();
        if (clientStatusId) {   
            const selectedStatus = $("#DDLStatusID").val();
            const selectedER = $("#DDLERId").val();
                $.ajax({
                        url: "@Url.Action("FilterClients", "Admin")",
                        type: "GET",
                        data: { ClientStatusID: clientStatusId,
                                ERID:erId },
                        success: function (data) {
                        SetSessionExpireTimer();
                        $('#divClientsList').html(data);
                        $("#DDLStatusID").val(selectedStatus);
                        $("#DDLERId").val(selectedER);
                        LoadClientsList();
                        
                    },
                    error: function (result) {
                        console.log("Filed Ajax");
                    }
            });
        } 
    }
        function LoadClientsList() {  

        $('#tblClients').DataTable({
        searching: true,
        'aoColumnDefs': [{
            'bSortable': false,
            'aTargets': [-1]
        }],
        "columns": [
            { "width": "10%" },
            { "width": "35%" },
            { "width": "25%" },
            { "width": "15%" },
            { "width": "15%" }
        ],
        "columnDefs": [
            { "type": "num", "targets": 0 }
        ],
        "order": [0, 'asc'],
        dom: 'l<"toolbar">frtip',
        initComplete: function () {
            $("div.toolbar").html('<a id="btnClaimExport" href="javascript:;" class="" title="Download"><i class="fa fa-lg fa-file-excel-o text-success"></i> </a>');
            
            $('#btnClaimExport').on('click', function () {
                const getclientStatusId=$("#DDLStatusID").val();
                const geterId=$("#DDLERId").val();            
                $.ajax({
                        url: "@Url.Action("DownloadClients", "Admin")",
                        type: "POST",
                        data: { ClientStatusID: getclientStatusId,
                                        ERID:geterId },
                        success: function (data) {
                        // Assuming data contains the URL to the file
                        const a = document.createElement('a');
                        a.style.display = 'none';
                        a.href = data;  // Use the correct variable `data` from the response
                        a.download = 'Clients.xlsx';  // Specify the default file name
                        document.body.appendChild(a);
                        a.click();  // Trigger the download
                    },
                    error: function (result)
                    {
                        console.log("Filed Ajax");
                    }
                });               
            }); 
            }
        });
    } 


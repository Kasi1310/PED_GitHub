@using WiseX.ViewModels.Admin
@model Allocation

@{
    var hidetableddiv = string.Empty;
    var HideTextdiv = string.Empty;
    if (Model.SelfAllocationList.Count == 0)
    {

        hidetableddiv = "hide";
    }
    else
    {
        HideTextdiv = "hide";

    }
}

<div class="panel panel-inverse" data-sortable-id="form-validation-1">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:;" class="btn btn-xs btn-icon btn-circle btn-warning collapsed" id="expandcollapse" data-click="panel-collapse" data-original-title="" title="" data-init="true"><i class="fa fa-minus"></i></a>
        </div>
        <h4 class="panel-title">Allocation & Error List</h4>
    </div>
    <div class="panel-body">
        <div class="pull-right">
            <span class="txt-primary">Please confirm to upload the valid files: </span>
            <input id="btnSubmit" type="button" value="Confirm" class="btn btn-xs btn-success m-b-10">
        </div>
        <div class="panel-body">
            <table id="tblfileallocation" class="table table-striped table-bordered table-hover @hidetableddiv">
                <thead>
                    <tr>
                        <th>Sno</th>
                        <th>Project Name</th>
                        <th>File Name</th>
                        <th>Total Page</th>
                        <th>Coder Name</th>
                        <th>Coding Team</th>
                        <th>Audit Name</th>
                        <th>Error Message</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (Model.SelfAllocationList.Count > 0)
                        {
                            int i = 0;
                            foreach (var item in Model.SelfAllocationList)
                            {
                                i++;
                                <tr>
                                    <td id="txtSno" class="tr1">@i</td>
                                    <td id="ProjectName" class="tr1">@item.ProjectName</td>
                                    <td id="FileName" class="tr1">@item.FileName</td>
                                    <td id="TotalPage" class="tr1">@item.TotalPage</td>
                                    <td id="CoderName" class="tr1">@item.CoderName</td>
                                    <td id="CodingTeam" class="tr1">@item.CodingTeam</td>
                                    <td id="AuditTeam" class="tr1">@item.AuditTeam</td>
                                    <td id="ErrorText" style="color:#ff0000 !important" class="tr1">@item.ErrorText</td>

                                </tr>

                            }
                        }
                        else
                        {

                            <tr>No Error Data</tr>
                        }
                    }

                </tbody>
            </table>
         </div>
        </div>
    </div>
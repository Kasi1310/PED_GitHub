@using WiseX.ViewModels.Admin;
@model IEnumerable<AllocatedList>

<div class="panel panel-inverse" data-sortable-id="form-validation-1">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:;" class="btn btn-xs btn-icon btn-circle btn-warning collapsed" id="expandcollapse" data-click="panel-collapse" data-original-title="" title="" data-init="true"><i class="fa fa-minus"></i></a>
        </div>
        <h4 class="panel-title">User File Allocation List</h4>
    </div>
    <div class="panel-body">
        <table id="tblAllocation" class="table table-striped table-bordered table-hover">
            <thead>
                <tr>
                    <th>Sno</th>
                    <th>Batch No</th>
                    <th>Project Name</th>
                    <th>Coding Team </th>
                    <th>Audit Team</th>
                    <th>Total Charts</th>
                    @*<th>Edit</th>*@
                </tr>
            </thead>
            <tbody>
                @{int i = 0;
                    foreach (var item in Model)
                    {
                        i++;
                        <tr id="@item.Id">
                            <td>@i</td>
                            <td>@item.Batch</td>
                            <td>@item.ProjectName</td>
                            <td>@item.ReviewResource</td>
                            <td>@item.AuditResource</td>
                            <td>@item.ChartCount</td>
                            @*<td class="tr1">
                                <button id="btnedit" onclick="EditManualAllocation('@item.Id')" title="Edit" class="fa fa-lg fa-edit  text-inverse form-control1" style="border:none; background-color:transparent"></button>
                                <button id="btnDelete" Onclick="ConfirmDelete('@item.Id')" title="Delete" class="fa fa-lg fa-trash-o  text-inverse form-control1 p-l-0 p-r-0" style="border:none; background-color:transparent"></button>
                            </td>*@
                        </tr>
                    } }
            </tbody>
        </table>
    </div>
</div>


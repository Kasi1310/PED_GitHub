@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.Admin;
@model List<BulkClientsDetailsValidationList>
@{
    string isAdmin = string.Empty;
    string errorClass = string.Empty;
    string isChecked = string.Empty;
    string isDisabled = string.Empty;
    string isSubmitable = string.Empty;

    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }

    //if (Model.Where(m => m.ErrorMessage != "" && m.ErrorMessage.ToLower() != "client already exists").Count() > 0)
    //{
    //    isSubmitable = "disabled";
    //}
}

<div class="panel panel-inverse dataTables_length" data-sortable-id="form-validation-1">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:;" class="btn btn-xs btn-icon btn-circle btn-default collapsed" id="expandcollapse" data-click="panel-collapse" data-original-title="" title="" data-init="true"><i class="fa fa-minus"></i></a>
        </div>
        <h4 class="panel-title">Clients List</h4>
    </div>
    <div class="panel-body">
        <div class="divConfirmUpload"><a id="btnConfirmUpload" href="javascript:;" class="btn btn-sm btn-primary" @isSubmitable>Upload</a></div>
        <table id="tblBulkUploadClients" class="table table-striped table-bordered table-hover">
            <thead>
                <tr>
                    <th><input type="checkbox" id="checkAlle" name="checkAlle" class="checkbox-css" /></th>
                    <th>ERROR MESSAGE</th>
                    <th>COMPANY ID </th>
                    <th>CLIENT NAME</th>
                    <th>RESIDENCY CODE</th>
                    <th>Year 1 FEE %</th>
                    <th>Year 2 FEE %</th>
                    <th>Year 3 FEE %</th>
                    <th>Year 4 FEE %</th>
                    <th>CONTRACT START DATE</th>
                    <th>CONTRACT RENEWED</th>
                    <th>CONTRACT EXPIRES</th>
                    <th>ACCOUNT OWNER</th>
                    <th>CHIEF</th>
                    <th>EMAIL</th>
                    <th>FISCAL</th>
                    <th>EMAIL</th>
                    <th>PHYSICAL LOCATION STREET</th>
                    <th>PHYSICAL LOCATION CITY</th>
                    <th>PHYSICAL LOCATION STATE</th>
                    <th>PHYSICAL LOCATION ZIP</th>
                    <th>NON-TRANSPORT BILLED</th>
                    <th>NON-TRANSPORT CHARGES ($)</th>
                    <th>CONTRACT FILE NAME</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>

                @{int i = 0;
                    foreach (var item in Model)
                    {
                        if(item.ErrorMessage.Trim() != "")
                        {
                            if (item.ErrorMessage == "Client Already Exists")
                            {
                                errorClass = "validationErrorRow";
                                isChecked = "";
                                isDisabled = "";
                            }
                            else
                            {
                                errorClass = "validationErrorRow";
                                isChecked = "";
                                isDisabled = "disabled";
                            }

                        }
                        else
                        {
                            errorClass = "";
                            isChecked = "checked";
                            isDisabled = "";
                        }
                        i++;
                <tr class="trClientsList @errorClass">
                    <td class="tr1"><input @isChecked type="checkbox" id="checkAlle" name="checkAlle" class="clsSelect checkbox-css @errorClass" @isDisabled /></td>
                    <td class="tr1 tdErrorMessage">@item.ErrorMessage</td>
                    <td class="tr1 tdClient">@item.Client</td>
                    <td class="tr1 tdDescription">@item.Description</td>
                    <td class="tr1 tdResidencyCode">@item.ResidencyCode</td>
                    <td class="tr1 tdFee1">@item.Fee1</td>
                    <td class="tr1 tdFee2">@item.Fee2</td>
                    <td class="tr1 tdFee3">@item.Fee3</td>
                    <td class="tr1 tdFee4">@item.Fee4</td>
                    <td class="tr1 tdContractStartSate">@item.ContractStartSate</td>
                    <td class="tr1 tdContractRenewed">@item.ContractRenewed</td>
                    <td class="tr1 tdContractExpires">@item.ContractExpires</td>
                    <td class="tr1 tdAccountOwner">@item.AccountOwner</td>
                    <td class="tr1 tdChief">@item.Chief</td>
                    <td class="tr1 tdCemail">@item.Cemail</td>
                    <td class="tr1 tdFiscal">@item.Fiscal</td>
                    <td class="tr1 tdFemail">@item.Femail</td>
                    <td class="tr1 tdPhysicalLocationStreet">@item.PhysicalLocationStreet</td>
                    <td class="tr1 tdPhysicalLocationCity">@item.PhysicalLocationCity</td>
                    <td class="tr1 tdPhysicalLocationState">@item.PhysicalLocationState</td>
                    <td class="tr1 tdPhysicalLocationZip">@item.PhysicalLocationZip</td>
                    <td class="tr1 tdNonTransportBilled">@item.NonTransportBilled</td>
                    <td class="tr1 tdNonTransportCharges">@item.NonTransportCharges</td>
                    <td class="tr1 tdContractFileName">@item.ContractFileName</td>
                    <td class="tr1 tdNotes">@item.Notes</td>

                </tr>
                    } }
            </tbody>
        </table>
    </div>
</div>


@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.Admin;
@model IEnumerable<ClientsDetailsList>
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    var RoleId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleID");

   
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}

<div class="panel panel-inverse" data-sortable-id="form-validation-1">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:;" class="btn btn-xs btn-icon btn-circle btn-default collapsed" id="expandcollapse" data-click="panel-collapse" data-original-title="" title="" data-init="true"><i class="fa fa-minus"></i></a>
        </div>
        <h4 class="panel-title">Clients List</h4>
    </div>
    <div class="panel-body">
            <div class="form-group row p-0">
             <label class="col-md-3 col-sm-3 col-form-label" for="StatusID">Client Status</label>
             <div class="col-md-3 col-sm-3">
                 <select id="DDLStatusID" name="StatusID" class="form-control" onchange="ddlClientStatus()">
                     <option value="0">-- Select Status --</option>
                     <option value="1">Previous</option>
                     <option value="2">Current</option>
                 </select>
             </div>

             <label class="col-md-3 col-sm-3 col-form-label" for="ERId">Enrollment Representative</label>
             <div class="col-md-3 col-sm-3">
                 <select id="DDLERId" name="ERId" class="form-control" onchange="ddlERepresentative()">
                     <option value="0">-- Select Representative --</option>
                     <option value="1">Amy King</option>
                     <option value="2">Pamela Roysdon</option>
                 </select>
             </div>            
            </div>
    </div>
  
    <div class="panel-body">      
        <br />
        @* <div id="clientListContainer"> *@
        <table id="tblClients" class="table table-striped table-bordered table-hover" style="width:100%">
            <thead>
                <tr>
                    @*<th>Sno</th>*@
                    <th>Company ID</th>
                    <th>Company Name</th>
                    <th>Residency Code</th>
                    @*<th>Contract Start Date</th>
                    <th>Contract Expiry Date</th>
                    <th>Contract Status</th>*@
                    <th>Active</th>
                    <th class="@isAdmin">Action</th>
                </tr>
            </thead>
            <tbody>

                @{int i = 0;
                    foreach (var item in Model)
                    {
                        i++;
                        <tr id="@item.ID">
                            @*<td id="txtSno" class="tr1">@i</td>*@
                            <td id="txtCompanyId" class="tr1">@item.CompanyId</td>
                            <td id="txtName" class="tr1">
                                @Html.Raw(item.CompanyName)
                                @*<a href="/Contract/Contracts/@item.CompanyName">@item.CompanyName</a>*@
                            </td>
                            <td id="txtResidencyCode" class="tr1">@item.ResidencyCode</td>
                            @*<td id="txtSignedDate" class="tr1">@item.ContractStartDate</td>
                            <td id="txtExpiryDate" class="tr1">@item.ContractExpiryDate</td>
                            <td id="txtNotes" class="tr1">@item.Notes</td>*@
                            <td id="txtStatus" class="tr1">@if (item.Active) { <span>Yes</span>} else {<span>No</span>}</td>

                            <td class="tr1 clsAction @isAdmin">
                                <button id="btnedit" onclick="EditClients('@item.ID')" title="Edit" class="fa fa-lg fa-edit @isAdmin text-inverse form-control1" style="border:none; background-color:transparent"></button>
                                @if (item.Active != false)
                                {
                                    <button id="btnDelete" Onclick="ConfirmDelete('@item.ID')" title="Delete" class="fa fa-lg fa-trash-o @isAdmin  text-inverse form-control1 p-l-0 p-r-0" style="border:none; background-color:transparent"></button>
                                }
                            </td>
                        </tr>
                    } }
            </tbody>
        </table>
       @*  </div> *@
    </div>
</div>


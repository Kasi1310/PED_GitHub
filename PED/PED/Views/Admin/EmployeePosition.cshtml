@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.Admin
@model Position
@{
    string isAdmin = string.Empty;
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    if (RolePermission == "R")
    {
        isAdmin = "hide";
    }
}
@section Styles {
    <link href='@Url.Content("~/css/DataTables.css")' rel="stylesheet" />
    <link href='@Url.Content("~/plugins/parsley/src/parsley.css")' rel="stylesheet" />
    <link href='@Url.Content("~/plugins/bootstrap-sweetalert/sweetalert.css")' rel="stylesheet" />
}
<input type="hidden" id="hrfEmployeePosition" value='@Url.Content("~/Admin/EmployeePosition/")' />
<div id="content" class="content">
    <ol class="breadcrumb pull-right">
        <li><a href="@Url.Action("Index","Home")">Home</a></li>
        <li><a href="javascript:;">Admin</a></li>
        <li class="active">Employee Position</li>
    </ol>
    <h1 class="page-header">Employee Position<small></small></h1>
    <div id="alertsuccess" class="alert alert-success alert-dismissable">
        <a href="#" class="close" data-dismiss="alert" aria-label="close">×</a>
        <strong>Success!</strong> Details saved.
    </div>
    <div id="alertinfo" class="alert alert-info alert-dismissable">
        <a href="#" class="close" data-dismiss="alert" aria-label="close">×</a>
        <strong>Sorry!</strong> Users are Mapped for the Employee Position.
    </div>
    <div id="divEmployeePositionform">
        @{ Html.RenderPartial("_EmployeePositionFrom", Model); }
    </div>
    <div id="divEmployeePositionList">
        @{ Html.RenderPartial("_EmployeePositionList", Model.PositionList); }

    </div>
</div>
@section Scripts
    {
    <script src='@Url.Content("~/js/DataTables.js")'></script>
    <script src='@Url.Content("~/plugins/parsley/dist/parsley.js")'></script>
    <script src='@Url.Content("~/js/CommonEvents.js")'></script>
    <script src='@Url.Content("~/plugins/bootstrap-sweetalert/sweetalert.min.js")'></script>
    <script src='@Url.Content("~/js/ApplicationError.js")'></script>
    <script type="text/javascript">
    $(document).ready(function () {
        LoadEmployeePositionList();
        $('#alertsuccess').hide();
        $('#alertinfo').hide();
        InitEvents();
        CancelTeam();
    });
    function createEmployeePosition()
    {
        var validationresult = $('#EmployeePositionfrm').parsley().validate();
        if (validationresult) {
            var Getname = $('#@Html.IdFor(m => m.PositionDetails.Name)').val();
            var GetActiveStatus = ($('.ActiveStatus:checked').val());
            var activ;
            if (GetActiveStatus == 1)
                activ = 1;
            else
                activ = 0;
            var GetId = $('#@Html.IdFor(m => m.PositionDetails.Id)').val();
            GetId = (GetId == "" ? 0 : GetId);
            var PositionDetails = JSON.stringify({
                Id: GetId,
                Name: Getname,
                Active: activ,
                Status:GetActiveStatus
            });
            var url = "@Url.Action("SaveEmployeePosition", "Admin")";
            var jsonData = PositionDetails;
            AjaxRequestJsonPostContent(url, jsonData, function (resp, status, req) {
                $('#divEmployeePositionList').html(resp);
                $('.collapse').hide();
                $('#btnEmployeePositionSubmit').val('Submit');
                $('#alertsuccess').show();
                $('#@Html.IdFor(m => m.PositionDetails.Id)').val('');
                setTimeout(function () {
                    $('#alertsuccess').hide();
                    $('#alertsuccess').removeClass('show');
                }, 2000);
                $('#Active').removeAttr('disabled');
                $('#InActive').removeAttr('disabled');
                $('#expandcollapse').find('i').removeClass('fa-minus').addClass('fa-plus');
                $('#EmployeePositionfrm').parsley().destroy();
                ClearForm();
                LoadEmployeePositionList();
            });
        }
    }

    function ClearForm()
    {
        $('#EmployeePositionfrm').find('input:text').val('');
        $("textarea").val("");
        $('#EmployeePositionfrm').find('input:radio').removeAttr('checked');
        $('#EmployeePositionfrm').find('select').val(0);
        $('#EmployeePositionDetails_Id').val('');
    }

    function EditEmployeePosition(ID)
    {
        var url = "@Url.Action("EditEmployeePosition", "Admin")";
        var jsonData = ID;
        AjaxRequestJsonPostContent(url, jsonData, function (resp, status, req) {
            $('#divEmployeePositionform').html(resp);
            var hfdisable = $('#hfactiveDisable').val();
            if (hfdisable == 'disabled') {
                $('#Active').attr('disabled','disabled');
                $('#InActive').attr('disabled', 'disabled');
                $('#divActiveStatus').attr('title','Sorry Cannot be Edited');
            }
            else
            {
                $('#Active').removeAttr('disabled');
                $('#InActive').removeAttr('disabled');
            }
            CancelTeam();
            $('#btnEmployeePositionSubmit').val('Update');
            $('#expandcollapse').find('i').removeClass('fa-plus').addClass('fa-minus');
            $('.collapse').collapse();
            $("#changeteam").html("Edit Employee Position");
            ScrollToTop();
        });
    }

        $('#btnEmployeePositionSubmit').live('click', function () {
            createEmployeePosition();
            $("#changeteam").html("Add Employee Position");
    });

        function LoadEmployeePositionList() {
            $('#tblEmployeePosition').DataTable({
            searching: true,
            'aoColumnDefs': [{
                'bSortable': false,
                'aTargets': [-1]
            }]
        });
    }
function CancelTeam(){
    $('#btnCancel').click(function (e) {
    swal({
        title: "Are you sure?",
        text: "Data in the page will be lost!",
        type: "info",
        showCancelButton: true,
        confirmButtonClass: 'btn-primary',
        confirmButtonText: 'Confirm'
    },
        function (isConfirm) {
            if (isConfirm) {
                location.href = $('#hrfEmployeePosition').val();
            }
        });
});
}
function ConfirmDelete(RID) {
    $("#alertsuccess").hide();
    $('#alertinfo').hide();
    swal({
        title: "Are you sure?",
        text: "You will not be able to recover this detail!",
        type: "error",
        showCancelButton: true,
        confirmButtonClass: 'btn-danger',
        confirmButtonText: 'Yes, delete it!'
    },
    function (isConfirm) {
        if (isConfirm) {
                var url = "@Url.Action("DeleteEmployeePosition", "Admin")";
            var jsonData = { ID: RID };
                AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {
                    if (resp.message == "Failed") {
                        $('#alertinfo').show();
                        setTimeout(function () {
                            $('#alertinfo').hide();
                            $('#alertinfo').removeClass('show');
                        }, 2000);
                        LoadEmployeePositionList();
                    }
                    else
                    {
                        $('#alertinfo').hide();
                        $('#divEmployeePositionList').html(resp);
                        ClearForm();
                        LoadEmployeePositionList();
                    }
                });
            }
            else {
                return false;
            }
    });
};
    </script>
}

@using PED.ViewModels.Contract;
@model Contracts
<div class="modal fade" id="RejectForm">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="panel panel-inverse">
                <div class="panel-heading">
                    <h4 class="panel-title"> Contract Comments</h4>
                </div>
                <form id="contractRejectfrm" method="post" class="form-horizontal" data-parsley-validate="true">
                    <div class="panel-body panel-form p-t-15 m-t-10">
                        <div class="form-group col-sm-6 col-md-6 col-lg-6">
                            <label class="control-label col-md-4 col-sm-4" for="Comments">Comments<span style="color:red">*</span></label>
                            <div class="col-md-6 col-sm-6 col-lg-6 controls" data-parsley-validate="true">
                                @Html.TextAreaFor(m => m.ClientContractDetails.Comments, new { @class = "form-control", @placeholder = "Enter Comments", data_parsley_required = "true" })
                            </div>
                        </div>
                        <div class="form-group col-sm-12 text-center">
                            <input type="button" id="btnRejectSubmit" class="btn btn-sm btn-primary m-r-5" value="Submit" />
                            <input type="button" id="btnRejectCancel" class="btn btn-sm btn-default m-r-5" value="Cancel" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
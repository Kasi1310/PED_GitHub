@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.Contract
@model Contracts
@{
    string isAdmin = string.Empty;

    var Changeproject = HttpContextAccessor.HttpContext.Session.Get<List<UserProjectRole>>("Changeproject");
    var RoleId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleID");
    var NotificationCount = HttpContextAccessor.HttpContext.Session.Get<string>("NotificationCount");
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");

    if (RoleId == "30133577-ba4d-4d74-8c17-575c99f6cc01")//Provider Enrollment Full Access
    {
        isAdmin = "hide";
    }
    if (RolePermission == "R")
    {
        isAdmin = "hide";

    }

}
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Contract</title>
    @section Styles {
        <link href='@Url.Content("~/css/DataTables.css")' rel="stylesheet" />
        <link href='@Url.Content("~/css/BootstrapDatepicker.css")' rel="stylesheet" />
        <link href='@Url.Content("~/plugins/DataTables/media/css/dataTables.bootstrap.min.css")' rel="stylesheet" />
        <link href='@Url.Content("~/plugins/simple-line-icons/css/simple-line-icons.css")' rel="stylesheet" />
        <link href='@Url.Content("~/plugins/bootstrap-sweetalert/sweetalert.css")' rel="stylesheet" />
        <style>
            td.details-control {
                background: url('~/img/details_open.png') no-repeat center center;
                cursor: pointer;
            }

            tr.shown td.details-control {
                background: url('~/img/details_close.png') no-repeat center center;
            }


            .input-daterange input {
                text-align: left !important;
            }

            #tblErrorList tfoot .form-control {
                padding-left: 3px !important;
                height: 20px;
                font-size: 11px;
                font-weight: normal;
            }

            tfoot {
                display: table-header-group !important;
            }

            .modal-dialog {
                width: 970px !important;
                margin: 30px auto;
            }

            .lbl-align {
                text-align: left !important;
                font-weight: 700;
            }

            #userForm hr {
                margin-top: 5px !important;
                margin-bottom: 10px !important;
            }

            #userForm h4 {
                margin: 0px;
                padding-left: 10px;
            }

            .head-div {
                float: right;
                margin-top: -30px;
            }
        </style>
    }

</head>
<body>
    <input type="hidden" id="hrfContractApproval" value='@Url.Content("~/Contract/ContractApproval/")' />
    <input type="hidden" id="hrfSearchClient" value='@Url.Content("~/Contract/GetSearchClient")' />
    <input type="hidden" id="hrfClientId" value="" />
    <input type="hidden" id="hrfContractId" value="" />
    <input type="hidden" id="hrfStatus" value="" />
    <input type="hidden" id="hfReviewYear" />
    <input type="hidden" id="hfrClientID" value="" />
    <input type="hidden" id="hfrDataClientID" value=0 />
    <div class="content" id="content">
        <ol class="breadcrumb pull-right">
            <li><a href="@Url.Action("Index","Home")">Home</a></li>
            <li><a href="javascript:;">Contract Approval</a></li>
            <li class="active">Contract Approval</li>
        </ol>
        <h1 class="page-header">Contract Approval<small></small></h1>
        <div id="divContractApprovalList">
            @{await Html.RenderPartialAsync("_ContractList", Model); }
        </div>

    </div>
    <div id="divContractRejectForm">
        @{await Html.RenderPartialAsync("_ContractRejectForm", Model); }
    </div>
</body>
</html>





@section Scripts{
    <script src='@Url.Content("~/js/DataTables.js")'></script>
    <script src='@Url.Content("~/plugins/parsley/dist/parsley.js")'></script>
    <script src='@Url.Content("~/plugins/DataTables/media/js/dataTables.bootstrap.js")'></script>
    <script src='@Url.Content("~/js/ui-modal-notification.demo.min.js")'></script>
    <script src='@Url.Content("~/plugins/bootstrap-sweetalert/sweetalert.js")'></script>
    <script src='@Url.Content("~/plugins/bootstrap-datepicker/js/bootstrap-datepicker.js")'></script>
    <script src='@Url.Content("~/plugins/masked-input/masked-input.min.js")'></script>
    <script src='@Url.Content("~/js/CommonUtils.js")'></script>
    <script type="text/javascript">
        $(document).ready(function () {
            Notification.init();
            InitControls();
            CancelTeam();
            Datatable();
            hides();
        });
        function hides()
        {
            var AE = '@isAdmin';
            if (AE == "AE") {

                $(".AEshow").addClass('show');
                $(".AEHide").addClass('hide');
            }
            else
            {
                $(".AEshow").addClass('hide');
                $(".AEHide").addClass('show');
            }
        }
        function Datatable()
        {
                var dtTblList;
              PageValue = $('#Page').val();
              if ($.fn.DataTable.isDataTable('#tblContractList')) {
                  dtTblList = $('#tblContractList').DataTable().ajax.reload();
                  //$('#tblChartList')
              } else {
                  dtTblList = $('#tblContractList').DataTable(
                     {
                         ajax: {
                             url: '@Url.Content("~/Contract/LoadList")',
                             type: "POST",
                             datatype: "json",
                             data: function (d) {
                                 // d.Page = "";
                             },
                             error: function (result) {
                                 console.log(result);
                             }
                         },
                         columns: [
                              { data: "version", name: "version" },
                             { data: "companyID", name: "companyID" },
                             { data: "companyName", name: "companyName" },
                             { data: "contractSignedDate", name: "contractSignedDate" },
                             { data: "contractExpiryDate", name: "contractExpiryDate" },
                             { data: "status", name: "status" }
                         ],

                         columnDefs: [{
                             targets: 0,
                             render: function (data, type, row, meta) {
                                 if ($('#hfrDataClientID').val() != row["id"]) {
                                     return '<img src="@Url.Content("~/img/details_open.png")" alt="expand/collapse" id="' + row["contractID"] + '"/>' + data;
                                 }
                                 else {
                                     return '<img src="@Url.Content("~/img/details_close.png")" alt="expand/collapse" id="' + row["contractID"] + '"/>' + data;
                                 }
                                 }
                         },
                         {
                             targets: 6,
                             render: function (data, type, row, meta) {
                                 return '<a href="' + row["fileName"] + '" id="' + row["id"] + '" class="fa fa-eye" target="_blank"></a>';
                             }
                         },
                         {
                             targets: 7,
                             render: function (data, type, row, meta) {
                                 return '<a href="javascript:;" id="' + row["contractID"] + '" class="btn btn-primary btn-xs btnApprove">Approve</a>';
                             }
                         },
                          {
                              targets: 8,
                              render: function (data, type, row, meta) {
                                  return '<a href="javascript:;" id="' + row["contractID"] + '" class="btn btn-warning btn-xs btnReject">Reject</a>';
                              }
                          }
                         ],

                         serverSide: true,
                         processing: true,
                         autoWidth: false,
                         order: [0, "asc"],
                         language: {
                             processing: "Processing...Please Wait"
                         }

                     })

                  $(dtTblList.table().container()).removeClass('form-inline');
                  $('#tblContractList tbody td img').live('click', function () {
                      var tr = $(this).closest('tr');
                      var row = dtTblList.row(tr);
                      if (row.child.isShown()) {
                          /* This row is already open - close it */
                          this.src = '@Url.Content("~/img/details_open.png")';
                          row.child.hide();
                          tr.removeClass('shown');
                      }
                      else {
                          /* Open this row */
                          this.src = '@Url.Content("~/img/details_close.png")';
                          var contractId = $(this).attr("id");
                          var check = '@Url.Content("~/Contract/ClientContractsLog?contractId=")' + contractId;
                          $.post(check, function (ChartError) {
                              row.child(ChartError).show();
                              tr.addClass('shown');
                          });
                      }
                  });

                  $('#tblContractList tbody td .btnApprove').live('click', function () {
                      var tr = $(this).closest('tr');
                      var row = dtTblList.row(tr);
                      var ContractId = $(this).attr("id");
                      $('#RejectForm').modal('show'); 
                      $('#hrfContractId').val(ContractId);
                      $('#hrfStatus').val("Approved");
                      SentToAEContractDetails()
                      });

                  $('#tblContractList tbody td .btnReject').live('click', function () {
                      $('#RejectForm').modal('show');
                      var tr = $(this).closest('tr');
                      var row = dtTblList.row(tr);
                      var contractId = $(this).attr("id");
                      $('#hrfStatus').val("Rejected");
                      $('#hrfContractId').val(contractId);
                      SentToAEContractDetails();
                     
                      });
              }
        }

        function SentToAEContractDetails()
        {
            $('#btnRejectSubmit').on('click', function () {
                var contractId = $('#hrfContractId').val();
                var Status =  $('#hrfStatus').val();
                var comments = $('#@Html.IdFor(m => m.ClientContractDetails.Comments)').val();
                var EmailContractDetails = JSON.stringify({
                    ContractID: contractId,
                    Comments: comments,
                    Status: Status
                });
                var url = "@Url.Action("EmailContractApprove", "Contract")";
                var jsonData = EmailContractDetails;
                AjaxRequestJsonPostContent(url, jsonData, function (resp, status, req) {
                    if (resp.msge = 'Success') {
                        $('#RejectForm').modal('hide');
                        CancelTeam();
                        InitControls();
                        Datatable();
                        $('#hrfStatus').val("");
                        $('#contractRejectfrm').find('input:text').val('');
                        $("textarea").val("");
                    }
                });
            });
        }
        function CancelTeam() {
            $('#btnRejectCancel').click(function (e) {
                swal({
                    title: "Are you sure?",
                    text: "Data in the page will be lost!",
                    type: "info",
                    showCancelButton: true,
                    confirmButtonClass: 'btn-primary',
                    confirmButtonText: 'Confirm'
                },
                function (isConfirm) {
                    if (isConfirm) {
                        location.href = $('#hrfContractApproval').val();
                    }
                });
            });
        }
    </script>
}


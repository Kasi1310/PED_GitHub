@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PED.ViewModels.Contract
@model Contracts
@{
    string isAdmin = string.Empty;
    string isPermission = string.Empty;
    var Changeproject = HttpContextAccessor.HttpContext.Session.Get<List<UserProjectRole>>("Changeproject");
    var RoleId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleID");
    var NotificationCount = HttpContextAccessor.HttpContext.Session.Get<string>("NotificationCount");
    var RolePermission = HttpContextAccessor.HttpContext.Session.Get<string>("SessionRoleAccess");
    string UserId = HttpContextAccessor.HttpContext.Session.Get<string>("SessionUserID");

    if (RoleId == "30133577-ba4d-4d74-8c17-575c99f6cc01")//Provider Enrollment Full Access
    {
        isPermission = "hide";
    }
    if (RoleId == "194c4cc1-4a1e-4861-abbb-302d02f7d825")
    {
        isAdmin = "AE";
    }
    if (RolePermission == "R")
    {
        isPermission = "hide";
    }

}
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Contract</title>
    @section Styles {
        <link href='@Url.Content("~/css/DataTables.css")' rel="stylesheet" />
        <link href='@Url.Content("~/css/BootstrapDatepicker.css")' rel="stylesheet" />
        <link href='@Url.Content("~/plugins/DataTables/media/css/dataTables.bootstrap.min.css")' rel="stylesheet" />
        <link href='@Url.Content("~/plugins/simple-line-icons/css/simple-line-icons.css")' rel="stylesheet" />
        <link href='@Url.Content("~/plugins/bootstrap-sweetalert/sweetalert.css")' rel="stylesheet" />
        <link href='@Url.Content("~/plugins/parsley/src/parsley.css")' rel="stylesheet" />

        <style>
            td.details-control {
                background: url('~/img/details_open.png') no-repeat center center;
                cursor: pointer;
            }

            tr.shown td.details-control {
                background: url('~/img/details_close.png') no-repeat center center;
            }


            .input-daterange input {
                text-align: left !important;
            }

            #tblErrorList tfoot .form-control {
                padding-left: 3px !important;
                height: 20px;
                font-size: 11px;
                font-weight: normal;
            }

            tfoot {
                display: table-header-group !important;
            }

            .modal-dialog {
                width: 970px !important;
                margin: 30px auto;
            }

            .lbl-align {
                text-align: left !important;
                font-weight: 700;
            }

            #userForm hr {
                margin-top: 5px !important;
                margin-bottom: 10px !important;
            }

            #userForm h4 {
                margin: 0px;
                padding-left: 10px;
            }

            .head-div {
                float: right;
                margin-top: -30px;
            }

            .ui-autocomplete {
                overflow: auto;
                height: 300px;
            }

            #divClientDetails .form-group {
                margin-right: 0px !important;
                margin-left: 0px !important;
                margin-bottom: 0px !important;
            }

            #divClientDetails .text-success {
                color: #009591 !important;
            }

            .ui-front {
                z-index: 2000 !important;
            }

            .text-decoration {
                text-decoration: none !important;
            }
        </style>
    }

</head>
<body>
    <input type="hidden" id="hrfContractDetails" value='@Url.Content("~/Contract/Contracts/")' />
    <input type="hidden" id="hrfSearchClient" value='@Url.Content("~/Contract/GetSearchClient")' />
    <input type="hidden" id="hrfClientId" value="" />
    <input type="hidden" id="hrfCompanyname" value="" />
    <input type="hidden" id="hrfContractId" value="" />
    <input type="hidden" id="hrfStatus" value="" />
    <input type="hidden" id="hrfStatusID" value="" />
    <input type="hidden" id="hfReviewYear" />
    <input type="hidden" id="hfrClientID" value="" />
    <input type="hidden" id="hfrDataClientID" value=0 />
    <input type="hidden" id="hrfSentBy" value="" />
    <input type="hidden" id="hrfMailTo" value="" />
    <input type="hidden" id="hrfMailAttachment" value="" />

    <div class="content" id="content">
        <ol class="breadcrumb pull-right">
            <li><a href="@Url.Action("Index","Home")">Home</a></li>
            <li><a href="javascript:;">Clients & Contracts</a></li>
            <li class="active">Contract</li>
        </ol>
        <h1 class="page-header">Contract<small></small></h1>

        <div class="panel panel-inverse" data-sortable-id="form-validation-1">
            <div class="panel-heading">
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-xs btn-icon btn-circle btn-default" id="expandcollapse" data-click="panel-collapse" data-original-title="" title="" data-init="true"><i class="fa fa-minus"></i></a>
                </div>
                <h4 class="panel-title" id="changeTeam">Client Search</h4>
            </div>
            <div id="divClientSearch">
                @{ await Html.RenderPartialAsync("_ClientSearch"); }
            </div>

            <div id="divContractList" class="m-10 hide">
                <h4>Contracts</h4>
                <hr />

                <ul class="nav nav-tabs customtab" role="tablist">
                    <li class="nav-item active"> <a class="nav-link" data-toggle="tab" id="tcontractdetails" href="#divClientContractDetails" role="tab"><span class="hidden-sm-up"><i class="fa fa-th-list"></i></span> <span class="hiddpen-xs-down">Contracts List</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-toggle="tab" id="tInsuranceContractDetails" href="#divInsuranceContractDetails" role="tab"><span class="hidden-sm-up"><i class="fa fa-list-ol"></i></span> <span class="hidpden-xs-down">Insurance Contract List</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-toggle="tab" id="tPassThruContract" href="#divPassThruContract" role="tab"><span class="hidden-sm-up"><i class="fa fa-file"></i></span> <span class="hidpden-xs-down">Pass-Thru Contract</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-toggle="tab" id="tCrewLogList" href="#divCrewLogList" role="tab"><span class="hidden-sm-up"><i class="fa fa-file"></i></span> <span class="hidpden-xs-down">Crew Log List</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-toggle="tab" id="tAnnualChargeRateDetails" href="#divAnnualChargeRateDetails" role="tab"><span class="hidden-sm-up"><i class="fa fa-list-ol"></i></span> <span class="hidpden-xs-down">Annual Charge Rate List</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-toggle="tab" id="tOtherDocumentDetails" href="#divOtherDocumentDetails" role="tab"><span class="hidden-sm-up"><i class="fa fa-file"></i></span> <span class="hidpden-xs-down">Other Documents List</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-toggle="tab" id="tCommonNotess" href="#divCommomNotes" role="tab"><span class="hidden-sm-up"><i class="fa fa-sticky-note"></i></span> <span class="hidpden-xs-down">Notes</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-toggle="tab" id="tversionhistory" href="#divVersionHistroy" role="tab"><span class="hidden-sm-up"><i class="fa fa-history"></i></span> <span class="hidpden-xs-down">History</span></a> </li>
                </ul>

                <div class="tab-pane active" id="divClientContractDetails" role="tabpanel">
                    <div id="ClientContractDetails">
                        @{ await Html.RenderPartialAsync("_ClientContractDetails", Model); }
                    </div>
                </div>
                <div class="tab-pane active" id="divInsuranceContractDetails" role="tabpanel">
                    <div id="InsuranceContractDetails">
                        @{ await Html.RenderPartialAsync("_ClientInsuranceContractDetails", Model); }
                    </div>
                </div>

                <div class="tab-pane active" id="divPassThruContract" role="tabpanel">
                    <div id="PassThruContract">
                        @{ await Html.RenderPartialAsync("_ContractPassThruContract", Model); }
                    </div>
                </div>
                <div class="tab-pane active" id="divCrewLogList" role="tabpanel">
                    <div id="CrewLogList">
                        @{ await Html.RenderPartialAsync("_ContractCrewLogList", Model); }
                    </div>
                </div>

                <div class="tab-pane active" id="divAnnualChargeRateDetails" role="tabpanel">
                    <div id="AnnualChargeRateDetails">
                        @{ await Html.RenderPartialAsync("_ContractAnnualChargeRateList", Model); }
                    </div>
                </div>
                <div class="tab-pane" id="divOtherDocumentDetails" role="tabpanel">
                    <div id="OtherDocumentDetails">
                        @{ await Html.RenderPartialAsync("_ContractOtherDocumentDetails", Model); }
                    </div>
                </div>
                <div class="tab-pane" id="divCommomNotes" role="tabpanel">
                    <div id="CommomNotes">
                        @{ await Html.RenderPartialAsync("_ContractNotes", Model); }
                    </div>
                </div>
                <div class="tab-pane" id="divVersionHistroy" role="tabpanel">
                    <div id="VersionHistroy">
                        @{ await Html.RenderPartialAsync("_ContractHistory", Model); }
                    </div>
                </div>

            </div>
            <div id="divContractApprovalList">
                @{await Html.RenderPartialAsync("_ContractList", Model); }
            </div>
            @if (Model.ClientsDetailsList != null)
            {
                <div id="divClientList">
                    @{await Html.RenderPartialAsync("_ClientList", Model); }
                </div>
            }
        </div>
    </div>
    <div id="divContractform">
        @{await Html.RenderPartialAsync("_ContractForm"); }
    </div>
    <div id="divNotesform">
        @{await Html.RenderPartialAsync("_CommentsForm"); }
    </div>
    <div id="divSendEmailform">
        @{await Html.RenderPartialAsync("_SendEmailForm"); }
    </div>
</body>
</html>

@section Scripts{
    <script src='@Url.Content("~/js/DataTables.js")'></script>
    <script src='@Url.Content("~/plugins/parsley/dist/parsley.js")'></script>
    <script src='@Url.Content("~/plugins/DataTables/media/js/dataTables.bootstrap.js")'></script>
    <script src='@Url.Content("~/js/ui-modal-notification.demo.min.js")'></script>
    <script src='@Url.Content("~/plugins/bootstrap-sweetalert/sweetalert.js")'></script>
    <script src='@Url.Content("~/plugins/bootstrap-datepicker/js/bootstrap-datepicker.js")'></script>
    <script src='@Url.Content("~/plugins/masked-input/masked-input.min.js")'></script>
    <script src='@Url.Content("~/js/CommonUtils.js")'></script>

    <script type="text/javascript">
        $(document).ready(function () {
            Notification.init();
            InitControls();
            CancelTeam();
            CancelNotes()
            ApprovalDatatable();
            ClientSearch();
            MailSearch();
            ClientEdit();
            BtnSearch();
            hides();
            LoadclientsList();
            $('#alertNotessuccess').hide();
            $("#tcontractdetails").click();
            $("#VersionHistroy").hide();
            $("#OtherDocumentDetails").hide();
            $("#CommomNotes").hide();
            $(".nav-link").click(function () {
                var tabid = this.id;
                if (tabid == "tcontractdetails") {
                    $("#ClientContractDetails").show();
                    $("#InsuranceContractDetails").hide();
                    $("#PassThruContract").hide();
                    $("#CrewLogList").hide();
                    $("#AnnualChargeRateDetails").hide();
                    $("#OtherDocumentDetails").hide();
                    $("#VersionHistroy").hide();
                    $("#CommomNotes").hide();
                }
                else if (tabid == "tInsuranceContractDetails") {
                    $("#InsuranceContractDetails").show();
                    $("#PassThruContract").hide();
                    $("#CrewLogList").hide();
                    $("#AnnualChargeRateDetails").hide();
                    $("#ClientContractDetails").hide();
                    $("#OtherDocumentDetails").hide();
                    $("#VersionHistroy").hide();
                    $("#CommomNotes").hide();
                }
                else if (tabid == "tPassThruContract") {
                    $("#PassThruContract").show();
                    $("#ClientContractDetails").hide();
                    $("#InsuranceContractDetails").hide();
                    $("#CrewLogList").hide();
                    $("#AnnualChargeRateDetails").hide();
                    $("#OtherDocumentDetails").hide();
                    $("#VersionHistroy").hide();
                    $("#CommomNotes").hide();
                }
                else if (tabid == "tCrewLogList") {
                    $("#CrewLogList").show();
                    $("#ClientContractDetails").hide();
                    $("#InsuranceContractDetails").hide();
                    $("#PassThruContract").hide();
                    $("#AnnualChargeRateDetails").hide();
                    $("#OtherDocumentDetails").hide();
                    $("#VersionHistroy").hide();
                    $("#CommomNotes").hide();
                }
                else if (tabid == "tAnnualChargeRateDetails") {
                    $("#AnnualChargeRateDetails").show();
                    $("#InsuranceContractDetails").hide();
                    $("#PassThruContract").hide();
                    $("#CrewLogList").hide();
                    $("#ClientContractDetails").hide();
                    $("#OtherDocumentDetails").hide();
                    $("#VersionHistroy").hide();
                    $("#CommomNotes").hide();
                }
                else if (tabid == "tversionhistory") {
                   $("#VersionHistroy").show();
                    $("#ClientContractDetails").hide();
                    $("#InsuranceContractDetails").hide();
                    $("#PassThruContract").hide();
                    $("#CrewLogList").hide();
                    $("#AnnualChargeRateDetails").hide();
                   $("#CommomNotes").hide();
                   $("#OtherDocumentDetails").hide();
                }
                else if (tabid == "tOtherDocumentDetails") {
                    $("#VersionHistroy").hide();
                    $("#ClientContractDetails").hide();
                    $("#InsuranceContractDetails").hide();
                    $("#PassThruContract").hide();
                    $("#CrewLogList").hide();
                    $("#AnnualChargeRateDetails").hide();
                    $("#CommomNotes").hide();
                    $("#OtherDocumentDetails").show();
                    ClearForm();
                }
                else if (tabid == "tCommonNotess") {
                    $("#VersionHistroy").hide();
                    $("#ClientContractDetails").hide();
                    $("#InsuranceContractDetails").hide();
                    $("#PassThruContract").hide();
                    $("#CrewLogList").hide();
                    $("#AnnualChargeRateDetails").hide();
                    $("#OtherDocumentDetails").hide();
                    $("#CommomNotes").show();
                    ClearForm();
                }

            });
        });

        function FeesChangeDisable()
        {
            if ($('#FeesChangedDate').text() == ' ')
                $("#FeesChangedDate").text('--');
                //$(".FeesChange").addClass('hide');
            //else
                //$(".FeesChange").removeClass('hide');
        }

        function logDatatable()
        {
            $("#divContractList").addClass('hide');
            $("#divContractList").addClass('show');
            var dtTblList;
            PageValue = $('#Page').val();
            if ($.fn.DataTable.isDataTable('#tblContarctHistoryTable')) {
                dtTblList = $('#tblContarctHistoryTable').DataTable().ajax.reload();

            } else
            {
                dtTblList = $('#tblContarctHistoryTable').DataTable(
                   {
                       ajax: {
                           url: '@Url.Content("~/Contract/ClientContractsLog1")',
                           type: "POST",
                           datatype: "json",
                           data: function (d) {
                               d.contractId = $('#hrfClientId').val();
                           },
                           error: function (result) {
                               console.log(result);
                           }
                       },
                       columns: [
                            { data: "version", name: "version" },
                           { data: "logTime", name: "date" },
                           { data: "userName", name: "actionby" },
                           { data: "status", name: "action" },
                           { data: "comments", name: "comments" },
                       ],
                       autoWidth: false,
                       order: [],
                       language: {
                           processing: "Processing...Please Wait"
                       }

                   })
                $(dtTblList.table().container()).removeClass('form-inline');


            }
        }

        function OtherDocumentDatatable() {
            $("#divContractList").addClass('hide');
            $("#divContractList").addClass('show');
            var dtTblList;
            if ($.fn.DataTable.isDataTable('#tblContractOtherDocumentTable')) {
                dtTblList = $('#tblContractOtherDocumentTable').DataTable().ajax.reload();

            } else {
                dtTblList = $('#tblContractOtherDocumentTable').DataTable(
                   {
                       ajax: {
                           url: '@Url.Content("~/Contract/ClientContractsOtherDocument")',
                           type: "POST",
                           datatype: "json",
                           data: function (d) {
                               d.contractId = $('#hrfClientId').val();
                           },
                           error: function (result) {
                               console.log(result);
                           }
                       },
                       columns: [
                           { data: "documentName", name: "documentname" },
                           { data: "uploadedBy", name: "uploaded by" },
                           { data: "uploadedOn", name: "uploaded on" },
                       ],
                       columnDefs: [
                       {
                           targets: 0,
                           render: function (data, type, row, meta) {
                               //console.log(row);
                               var DocName = row["documentName"];
                               var fileName = row["fileName"];
                               var clientId = row["clientId"];

                               var linktext = '@Html.ActionLink("Doc*","ViewOtherContractFile", "Contract", new { fileName = "FN**", clientId = "CI**"}, new { @target = "_blank", style = "border:none; background-color:transparent;display: initial;" })';
                               linktext = linktext.replace('FN**', escape(fileName)).replace('CI**', clientId).replace('Doc*', DocName);
                               return linktext
                               //'<a href="' + row["fileName"] + '" id="' + row["id"] + '" target="_blank" style="border:none; background-color:transparent;display: initial;">' + row["documentName"] + '</a>';
                           }
                       },
                       {
                           targets: 3,
                           render: function (data, type, row, meta) {
                               return '<a href="javascript:;" id="' + row["id"] + '" class="btnOtherDocFilesdelete fa fa-lg fa-trash-o text-inverse form-control1 p-l-0 p-r-0 m-5 @isPermission" style="border:none; background-color:transparent;display: initial;"></a>';

                           }
                       }
                       ],
                       autoWidth: false,
                       order: [0, "desc"],
                       language: {
                           processing: "Processing...Please Wait"
                       }

                   })
                $(dtTblList.table().container()).removeClass('form-inline');

                $('#tblContractOtherDocumentTable tbody td .btnOtherDocFilesdelete').live('click', function () {
                    var tr = $(this).closest('tr');
                    var DocID = $(this).attr("id");

                    ConfirmOtherDocumentDelete(DocID);
                });
            }
        }

        function ConfirmOtherDocumentDelete(DocID) {
            var response = swal({
                title: "Are you sure?",
                text: "You will not be able to recover this detail!",
                type: "error",
                showCancelButton: true,
                confirmButtonClass: 'btn-danger',
                confirmButtonText: 'Yes, delete it!'
            },
                function (isConfirm) {
                    if (isConfirm) {
                        var url = "@Url.Action("DeleteOtherDocument", "Contract")";
                        var jsonData = { Id: DocID };
                        AjaxRequestJsonPost(url, jsonData, function (resp, status, req) {

                            OtherDocumentDatatable();
                            var formData = new FormData();
                            formData.append('companyId', $('#hrfClientId').val());
                            formData.append('Version', "v");
                            formData.append('ContractId', $('#hrfContractId').val());
                            formData.append('Status', 'Other Documents Deleted');

                            var url = "@Url.Action("UpdateViewDetails", "Contract")";
                            $.ajax({
                                url: url,
                                type: "POST",
                                contentType: false, // Not to set any content header
                                processData: false, // Not to process data
                                data: formData,
                                success: function (result) {
                                    logDatatable();
                                    OtherDocumentDatatable();
                                    NotesDatatable();
                                },
                                error: function (err) {

                                }
                            });
                        });
                    }
                    else {
                        return false;
                    }
                });
        };


        function MailSearch() {
            var eleClientSearch = $('#MailTo').autocomplete({
                scroll: true,
                minLength: 0,
                source: function (request, response) {
                    $.ajax({
                        type: "POST",
                        dataType: "json",
                        url: "@Url.Action("GetSearchClientEmployee", "Contract")",
                        data: {
                            Prefix: request.term,
                            clientId: $('#hrfClientId').val(),
                            Mailto: $('#MailTo').val()
                        },
                        success: function (data) {
                            response($.map(data, function (item) {
                                return { label: item.value, value: item.value, mail: item.email };
                            }));
                        },
                        error: function (req, status, error) {
                        }
                    });
                },
                select: function (event, ui) {
                    if ($("#MailTo").val() === "")
                        $("#hrfMailTo").val("");

                    var inp = $("#hrfMailTo");

                    if (inp.val() === "") {
                        $('#hrfMailTo').val(ui.item.mail);
                    }
                    else {
                        var LastValue = splitCurrentText($('#hrfMailTo').val());
                        LastValue.pop();
                        LastValue.push(ui.item.mail);
                        LastValue.push("");
                        $('#hrfMailTo').val(LastValue.join(","));
                    }
                    var LastValue = splitCurrentText(this.value);
                    LastValue.pop();
                    LastValue.push(ui.item.value);
                    LastValue.push("");
                    this.value = LastValue.join(",");
                    return false;
                },
                change: function (event, ui) {
                    if ($.trim($("#MailTo").val()) === "")
                        $("#hrfMailTo").val("");
                }
            }).focus(function () {
                $(this).autocomplete("search", "");
                return false;
            });
        }

        function splitCurrentText(LastTerm) {

            return LastTerm.split(/,\s*/);
        }

        function GetCurrentSearchTerm(LastTerm) {

            return splitCurrentText(LastTerm).pop();
        }

        $('#btnSendMail').on('click', function () {

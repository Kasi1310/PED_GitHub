    <script type="text/javascript">
        function InsuranceContractDatatable()
        {
            $("#divContractList").addClass('hide');
            $("#divContractList").addClass('show');
            var dtTblList;
            PageValue = $('#Page').val();
            if ($.fn.DataTable.isDataTable('#tblInsuranceContractList')) {
                dtTblList = $('#tblInsuranceContractList').DataTable().ajax.reload();

            } else {
                dtTblList = $('#tblInsuranceContractList').DataTable(
                    {
                        ajax: {
                            url: '@Url.Content("~/Contract/InsuranceContractList")',
                            type: "POST",
                            datatype: "json",
                            data: function (d) {
                                d.id = $('#hrfClientId').val();
                            },
                            error: function (result) {
                                //console.log(result);
                            }
                        },
                        columns: [
                            { data: "documentType", name: "documentType" },
                            { data: "insuranceContractName", name: "insuranceContractName" },
                            { data: "effectiveDate", name: "effectiveDate" },
                            { data: "termedDate", name: "termedDate" }
                        ],

                        columnDefs: [
                            {
                                targets: 4,
                                render: function (data, type, row, meta) {
                                    if (row["fileName"] != "") {
                                        var b = InsuranceContractAction(row["insuranceContractId"], row["fileName"], row["id"]);
                                        return b;
                                    }
                                    else {
                                        return '';
                                    }
                                }
                            },
                        ],

                        serverSide: true,
                        processing: true,
                        autoWidth: false,
                        order: [0, "desc"],
                        language: {
                            processing: "Processing...Please Wait"
                        }

                    });

                $(dtTblList.table().container()).removeClass('form-inline');
            }
        }


        function InsuranceContractAction(insuranceContractId, fileName, id) {
            var linktext = '@Html.ActionLink("", "ViewInsuranceContractFile", "Contract", new { fileName = "FN**", insuranceContractId = "II**", id="Id**" }, new { @target = "_blank", @class = "fa fa-eye text-inverse form-control1 p-l-0 p-r-0 m-5 text-decoration" })';
            linktext = linktext.replace('FN**', escape(fileName)).replace('II**', insuranceContractId).replace('Id**', id);

            return linktext;
        }
    </script>


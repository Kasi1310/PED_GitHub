        function SaveNotes(status)
        {
            var GetId = $('#hrfCommonNotesId').val();
            GetId = (GetId == "" ? 0 : GetId);
            var GetClientId = $('#hrfClientId').val();
            var GetContractId = $('#hrfContractId').val();
            var GetInsuranceContractId=$('#@Html.IdFor(m => m.ClientsDetails.InsuranceContractID)').val()
            var GetNotes = $('#CommonNote').val();

            var ClientContractNoteDetails = JSON.stringify({
                ID: GetId,
                ClientId: GetClientId,
                ContractId: GetContractId,
                InsuranceContractId: GetInsuranceContractId,
                Notes: GetNotes

            });
            var url = "@Url.Action("SaveClientContractNotes", "Contract")";
            var formData = new FormData();
            formData.append('Id', GetId);
            formData.append('ClientId', GetClientId);
            formData.append('ContractId', GetContractId);
            formData.append('InsuranceContractId', GetInsuranceContractId);
            formData.append('Notes', GetNotes);

            $.ajax({
                url: url,
                type: "POST",
                contentType: false,
                processData: false,
                data: formData,
                success: function (result) {
                    ClientDetailsLoad();
                    $("#CommonNote").val("");
                    $("#hrfCommonNotesId").val("");
                    $('#@Html.IdFor(m => m.ClientsDetails.InsuranceContractID)').val(0);
                },
                error: function (err) {
                }
            });
        }



